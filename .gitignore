# Zsh cache / compiled
.zcompdump
.zcompdump-*
*.zwc

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Editor artifacts
.vscode/*
.vscode/**/*
!.vscode/extensions.json
.idea/

# Temp / scratch artifacts
*.tmp
*.temp
*.bak
*.log

# Track only own cb-*.md files; everything else in .github/ stays local
# (unreviewed/unlicensed content from awesome-copilot, future extension-managed files, etc.)
.github/*
!.github/copilot-instructions.md
!.github/cb-*.md
!.github/instructions/
!.github/agents/
!.github/skills/
!.github/prompts/
.github/instructions/*
.github/agents/*
.github/skills/*
.github/prompts/*
!.github/instructions/cb-*.md
!.github/agents/cb-*.md
!.github/skills/cb-*.md
!.github/prompts/cb-*.prompt.md

# local: configuratins and variables, may contain sensitive info (e.g., API keys)
.claude/settings.local.json
.claude/memory/
.claude/plans/

# Environment files — may contain secrets
.env
.env.*

# Local scratch space — never commit
# Convention: _local/ dirs are for test dumps, scratch work, ad-hoc experiments
_local/

# Raw Obsidian notes staged for migration into docs/ — NOT sanitized.
# Contains real WiFi SSIDs, disk UUIDs, and MAC addresses; this repo is public.
# Migrate into docs/{setup,troubleshooting,reference}/ (see docs/setup/MIGRATION.md),
# then delete. Never commit the raw notes.
Obsidian_Example/

# Local config overrides — may contain sensitive data (e.g., credentials, API keys)
# Convention: foo.local or foo.local.conf overrides the tracked foo config (not committed)
*.local.*
