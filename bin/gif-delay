#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# Show per-frame timing and playback speed details for animated GIFs.

# set options
set -o errtrace
#set -o errexit
set -o pipefail
set -o nounset
(( ${DEBUG_LVL:-0} >= 2 )) && set -o xtrace
IFS=$'\t\n\0'

# traps
#trap 'rc=$?; \
#      printf "ERROR(%s) in %s:%s\n  -> %s\n  -> %s\n" "${rc}" \
#             "${0:-N/A}" "${LINENO:-N/A}" "${FUNCNAME[@]:-N/A}" \
#             "${BASH_COMMAND:-N/A}"; \
#      exit $rc' ERR
trap 'printf "\nINTERRUPT\n"; exit 1' SIGINT SIGTERM
#trap 'rc=$?; printf "EXIT(%s)\n" "$rc"; exit $rc' EXIT

# Logging
#p_msg() { printf '%s\n' "$*"; }
#p_nfo() { printf '\033[32mINFO\033[0m %s\n' "$*"; }
#p_war() { printf '\033[33mWARNING\033[0m %s\n' "$*" >&2; }
p_err() { printf '\033[31mERROR\033[0m: %s\n' "$*" >&2; }
#p_dbg() { (( "${1:-0}" <= "${DEBUG_LVL:-0}" )) && printf '\033[36mDEBUG\033[0m: %s\n' "${*:2}" >&2 || true; }

# Usage
p_usg() { printf 'Usage: %s  FILE...\n' "$(basename "$0")"; }
p_hlp() {
  p_usg
  cat <<EOF

About:
  Simple wrapper for 'identify' (imagemagick) that returns the delay (speed)
  in 100ths of a second of all frames in a given gif file.

Options:
  -d, --delay-only   Print the delay only (default: print frame index + delay)
  -a, --average      Print the average (rounded) delay of all frames

Examples:
  # print frame index + delay in 1/100 sec
  $(basename "$0") infile.gif
  #1 8
  #2 8
  #3 8
  #4 7
  #5 8

  # print delay in 1/100 sec only (omit the "#x " frame index prefix)
  $(basename "$0") -d infile.gif
  8
  8
  8

  # the average delay in 1/100 for all frames
  $(basename "$0") -a infile.gif
  8

Convert:
  One can change the speed of a given gif file using convert (imagemagick).

  # Change the speed of the above mentioned infile.gif (8x100 average) ..
  # .. to 5/100 sec. delay (speed up)
  convert -delay 10x100 infile.gif outfile.gif

  # .. to 15/100 sec. delay (slow down), the 'x100' can be omitted (default)
  convert -delay 15 infile.gif outfile.gif
EOF
}

# parse arguments
declare format="#%s %T"
declare average=false
declare infile
parse_args() {
  if [[ -z "${1:-}" ]]; then
    p_usg
    exit 1
  fi
  while [[ -n "$1" ]]; do
    case $1 in
      -d|--delay-only)
        format="%T"
        shift
        ;;
      -a|--average)
        average=true
        shift
        ;;
      -h|--help)
        p_hlp
        exit 0
        ;;
      -*)
        p_err "unknown argument: $1"
        exit 1
        ;;
      *)
        break
        ;;
    esac
  done

  if [[ -z "${1:-}" ]]; then
    p_err "missing file argument"
    exit 1
  fi
  if (( $# > 1 )); then
    p_err "too many arguments, provide only a single file"
    exit 1
  fi
  if [[ ! -f "$1" ]]; then
    p_err "file not found: $1"
    exit 1
  fi
  infile="$1"
}

gif_delay() {
  # print delays or average
  if $average; then
    local delay_sum
    if ! delay_sum="$(identify -format "%T+" "${infile}")"; then
      p_err "error processing gif file"
      exit 1
    fi
    local pluses="${delay_sum//[^+]}"
    local -i frame_count="${#pluses}"
    printf "%s\n" "$(((${delay_sum}0)/frame_count))"
  else
    identify -format "${format}\n" "${infile}"
  fi
}

main() {
  parse_args "$@"
  gif_delay
}

main "$@"
