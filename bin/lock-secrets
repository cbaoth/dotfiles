#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# lock-secrets: best-effort lock of all known secret stores (KeePassXC, GNOME
# keyring, optionally the SSH agent).
#
# Neither swaylock nor systemd-suspend tell secret stores that the session is
# no longer attended, so an unlocked KeePassXC database and an unlocked keyring
# survive both. This script closes that window; it is wired into the swayidle
# hooks in dotfiles/.config/sway/config.
#
# Every step is best effort and independent: a store that is absent, already
# locked, or misbehaving is skipped, never fatal. The script always exits 0 so
# it can be chained after swaylock without breaking the caller.

# set options (see also bin/sway-awake for the house pattern)
set -o errtrace
#set -o errexit
set -o pipefail
set -o nounset
(( ${DEBUG_LVL:-0} >= 2 )) && set -o xtrace
IFS=$'\t\n'

# traps
trap 'printf "\nINTERRUPT\n" >&2; exit 1' SIGINT SIGTERM

# Logging
p_err() { printf '\033[31mERROR\033[0m: %s\n' "$*" >&2; }
p_warn() { printf '\033[33mWARN\033[0m: %s\n' "$*" >&2; }
p_info() { (( VERBOSE )) && printf '%s\n' "$*"; return 0; }

# {{{ = CONSTANTS ============================================================
# KeePassXC exposes lockAllDatabases on the session bus. This works for the
# flatpak build too: the name is proxied onto the session bus by xdg-dbus-proxy.
declare -r KPXC_NAME="org.keepassxc.KeePassXC.MainWindow"
declare -r KPXC_PATH="/keepassxc"

# freedesktop Secret Service, implemented here by gnome-keyring-daemon.
declare -r SECRETS_NAME="org.freedesktop.secrets"
declare -r SECRETS_PATH="/org/freedesktop/secrets"

# The "session" collection is the ephemeral in-memory one; it holds no
# persisted secrets and cannot meaningfully be locked.
declare -r SECRETS_SKIP="${SECRETS_PATH}/collection/session"

declare -i VERBOSE=0
declare -i DRY_RUN=0
declare -i CLEAR_SSH=0
# }}} = CONSTANTS ============================================================

# {{{ = HELPERS =============================================================
usage() {
  cat <<-EOF
	Usage: lock-secrets [OPTIONS]

	Lock all known secret stores. Best effort: absent or already-locked stores
	are skipped silently, the exit code is always 0.

	Options:
	  -s, --ssh        also flush all identities from the SSH agent (ssh-add -D)
	  -v, --verbose    report what was locked
	  -n, --dry-run    print the actions instead of performing them
	  -h, --help       show this help

	Note on --ssh: the SSH keys on this host are provided by KeePassXC's agent
	integration, and KeePassXC removes them itself when the database is locked
	(per-entry "Remove key from agent when database is closed or locked").
	--ssh is the belt-and-braces variant for keys added by other means; it costs
	a re-unlock of KeePassXC to get them back.
	EOF
}

parse_args() {
  while (( $# > 0 )); do
    case "$1" in
      -s|--ssh) CLEAR_SSH=1 ;;
      -v|--verbose) VERBOSE=1 ;;
      -n|--dry-run) DRY_RUN=1; VERBOSE=1 ;;
      -h|--help) usage; exit 0 ;;
      *) p_err "unknown option: $1"; usage >&2; exit 2 ;;
    esac
    shift
  done
}

# Is a well-known name currently owned on the session bus?
bus_has_name() {
  local -r name="$1"
  busctl --user status "${name}" &>/dev/null
}
# }}} = HELPERS =============================================================

# {{{ = LOCK STEPS ===========================================================
lock_keepassxc() {
  if ! bus_has_name "${KPXC_NAME}"; then
    p_info "KeePassXC: not running, skipped"
    return 0
  fi
  if (( DRY_RUN )); then
    p_info "KeePassXC: would call ${KPXC_NAME}.lockAllDatabases"
    return 0
  fi
  if busctl --user call "${KPXC_NAME}" "${KPXC_PATH}" \
       "${KPXC_NAME}" lockAllDatabases &>/dev/null; then
    p_info "KeePassXC: databases locked"
  else
    p_warn "KeePassXC: lockAllDatabases failed"
  fi
}

# Lock every persistent Secret Service collection (gnome-keyring: "login",
# "Default_keyring", ...). Locking an already-locked collection is a no-op.
lock_keyring() {
  if ! bus_has_name "${SECRETS_NAME}"; then
    p_info "keyring: no Secret Service on the bus, skipped"
    return 0
  fi

  local collections
  if ! collections="$(busctl --user call "${SECRETS_NAME}" "${SECRETS_PATH}" \
       org.freedesktop.DBus.Properties Get ss \
       org.freedesktop.Secret.Service Collections 2>/dev/null)"; then
    p_warn "keyring: could not enumerate collections"
    return 0
  fi

  local -a paths=()
  mapfile -t paths < <(grep -oE '/org/freedesktop/secrets/collection/[^"]+' \
                         <<<"${collections}" | grep -Fxv "${SECRETS_SKIP}")
  if (( ${#paths[@]} == 0 )); then
    p_info "keyring: no lockable collections"
    return 0
  fi

  local path
  for path in "${paths[@]}"; do
    if (( DRY_RUN )); then
      p_info "keyring: would lock ${path##*/}"
      continue
    fi
    if busctl --user call "${SECRETS_NAME}" "${SECRETS_PATH}" \
         org.freedesktop.Secret.Service Lock ao 1 "${path}" &>/dev/null; then
      p_info "keyring: locked ${path##*/}"
    else
      p_warn "keyring: failed to lock ${path##*/}"
    fi
  done
}

lock_ssh_agent() {
  (( CLEAR_SSH )) || return 0
  if [[ -z "${SSH_AUTH_SOCK:-}" ]] || ! ssh-add -l &>/dev/null; then
    p_info "ssh-agent: no agent or no identities, skipped"
    return 0
  fi
  if (( DRY_RUN )); then
    p_info "ssh-agent: would flush all identities"
    return 0
  fi
  if ssh-add -D &>/dev/null; then
    p_info "ssh-agent: identities flushed"
  else
    p_warn "ssh-agent: could not flush identities"
  fi
}
# }}} = LOCK STEPS ===========================================================

main() {
  parse_args "$@"
  lock_keepassxc
  lock_keyring
  lock_ssh_agent
  return 0
}

main "$@"
