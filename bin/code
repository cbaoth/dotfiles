#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# VS Code wrapper: overrides XDG_CURRENT_DESKTOP to include GNOME when running
# outside a recognised desktop (e.g. Sway). Electron's safeStorage checks this
# variable; unrecognised desktops cause safeStorage.isEncryptionAvailable() to
# return false, so VS Code falls back to basic-text secret storage and loses
# access to stored credentials. portals.conf handles backend selection, so
# changing XDG_CURRENT_DESKTOP here does not affect file picker or screen share.

case "${XDG_CURRENT_DESKTOP:-}" in
  *GNOME*|*KDE*) ;;
  *) export XDG_CURRENT_DESKTOP="GNOME" ;;
esac

exec /usr/share/code/code "$@"
