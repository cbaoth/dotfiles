#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# foot-fzf-pick: pick line(s)/token(s) from piped terminal text via fzf and copy
# the selection to the Wayland clipboard. Invoked by foot's pipe-visible /
# pipe-scrollback key bindings (see ~/.config/foot/foot.ini): foot pipes the
# visible screen or full scrollback to this script's stdin. Because foot runs
# the pipe command WITHOUT a tty, the interactive fzf picker is launched in a
# fresh foot window reading a temp copy of that text.

set -euo pipefail

main() {
  command -v fzf > /dev/null   || { printf 'foot-fzf-pick: fzf not found\n' >&2; exit 1; }
  command -v wl-copy > /dev/null || { printf 'foot-fzf-pick: wl-copy not found\n' >&2; exit 1; }

  local tmp list
  tmp="$(mktemp --tmpdir foot-fzf-pick.XXXXXX)"
  list="$(mktemp --tmpdir foot-fzf-pick-list.XXXXXX)"
  local -r tmp list
  trap 'rm -f "${tmp}" "${list}"' EXIT

  # foot pipes the captured text on our stdin; stash it for the picker window.
  cat > "${tmp}"

  # Candidate list: non-blank whole lines first, then unique whitespace-split
  # tokens (paths, hashes, words) — so a full line or a single token can be
  # grabbed. `awk '!seen'` dedups while preserving order.
  { grep -vE '^[[:space:]]*$' "${tmp}"; grep -oE '[^[:space:]]+' "${tmp}"; } \
    | awk '!seen[$0]++' > "${list}"

  # Launch fzf in a new foot window (this process has no controlling tty).
  # Command substitution in the inner shell strips any trailing newline so a
  # single pick pastes cleanly without auto-executing; internal newlines from a
  # multi-select are preserved. Pass the list path as $1 to avoid quoting games.
  # shellcheck disable=SC2016  # $1/$sel are expanded by the inner sh, not bash
  foot --app-id=footpick --title='pick → clipboard' \
    sh -c 'sel="$(fzf --multi --no-sort --height=100% --prompt="copy> " < "$1")" \
           && [ -n "${sel}" ] && printf %s "${sel}" | wl-copy' \
    foot-fzf-pick "${list}"
}

main "$@"
