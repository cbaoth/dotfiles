#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# Toggle keyboard layout (Colemak ↔ QWERTY) for both Wayland and XWayland.
#
# swaymsg xkb_switch_layout covers native Wayland apps; setxkbmap on DISPLAY=:0
# is required separately because XWayland does not propagate Sway's XKB group
# changes to its X11 clients (Wine/Proton games, legacy X11 apps).

swaymsg input type:keyboard xkb_switch_layout next

layout=$(swaymsg -t get_inputs \
  | jq -r '[.[] | select(.type == "keyboard") | .xkb_active_layout_name] | first')

# Sync the XWayland X11 keyboard map to match the new Wayland layout.
if [[ "${layout}" == *"QWERTY"* ]]; then
  DISPLAY=:0 setxkbmap -layout us
else
  DISPLAY=:0 setxkbmap -layout us -variant colemak
fi

notify-send --expire-time=2000 "Keyboard Layout" "${layout:-unknown}"
