#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# Vivaldi browser wrapper:
#   --disable-features=Vulkan  incompatible with --ozone-platform=wayland on
#                              Nvidia proprietary drivers. Remove when switching
#                              to nvidia-open or Nouveau.
#   XDG_CURRENT_DESKTOP=GNOME  Electron's safeStorage.isEncryptionAvailable()
#                              returns false for unrecognised desktops (sway),
#                              causing credential storage to fall back to
#                              basic-text. portals.conf handles portal backend
#                              selection, so this does not affect file pickers.

case "${XDG_CURRENT_DESKTOP:-}" in
  *GNOME*|*KDE*) ;;
  *) export XDG_CURRENT_DESKTOP="GNOME" ;;
esac

exec /usr/bin/vivaldi-stable --disable-features=Vulkan "$@"
