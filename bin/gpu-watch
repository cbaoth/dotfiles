#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# gpu-watch: Log NVIDIA GPU power/clocks/temp, and report whether a power cap
#            was actually reached.

# set options
# -e omitted intentionally: the sampling loop must survive a transient
# nvidia-smi hiccup rather than abandoning an in-progress gaming session.
set -o pipefail
set -o nounset
(( ${DEBUG_LVL:-0} >= 2 )) && set -o xtrace

# {{{ = CONSTANTS =============================================================

declare -r DEFAULT_INTERVAL=2
declare -r LOG_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/gpu-watch"

# }}} = CONSTANTS =============================================================

# {{{ = ARGUMENTS =============================================================

declare -i interval="${DEFAULT_INTERVAL}"
declare log_file=""
declare -i gpu_index=0

# }}} = ARGUMENTS =============================================================

# {{{ = FUNCTIONS =============================================================

usage() {
  cat <<EOF
Usage: gpu-watch [OPTIONS] [--] [COMMAND..]

Sample GPU power draw, clocks and temperature to a CSV, then print a summary.

Without COMMAND, samples until Ctrl-C. With COMMAND, samples while it runs.

Options:
  -i, --interval SEC   Sample interval (default: ${DEFAULT_INTERVAL})
  -o, --output FILE    CSV path (default: ${LOG_DIR}/<timestamp>.csv)
  -g, --gpu INDEX      GPU index (default: 0)
  -h, --help           This help

Why: a power cap only proves anything if the card actually REACHES it. If a
game never draws more than the cap, a crash-free session says nothing about
whether the cap works. This tells you which case you are in.

Examples:
  gpu-watch                       # sample until Ctrl-C, then summarise
  gpu-watch -i 1                  # 1s resolution
  gpu-watch -- glxgears           # sample for the lifetime of a command

Background: docs/troubleshooting/gpu-xid79-bus-fall-off.md
EOF
}

p_err() { printf 'ERROR: %s\n' "$*" >&2; }

parse_args() {
  while (( $# > 0 )); do
    case "$1" in
      -i|--interval)
        [[ -z "${2:-}" ]] && { p_err "--interval requires a value"; exit 1; }
        interval="$2"; shift 2 ;;
      -o|--output)
        [[ -z "${2:-}" ]] && { p_err "--output requires a value"; exit 1; }
        log_file="$2"; shift 2 ;;
      -g|--gpu)
        [[ -z "${2:-}" ]] && { p_err "--gpu requires a value"; exit 1; }
        gpu_index="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      --) shift; break ;;
      -*) p_err "unknown option: $1"; usage >&2; exit 1 ;;
      *) break ;;
    esac
  done
  CMD=("$@")
}

# Print max/avg power and, crucially, whether the configured cap was reached.
summarise() {
  [[ -s "${log_file}" ]] || { printf '\nNo samples collected.\n'; return 0; }

  local -r limit="$(nvidia-smi --id="${gpu_index}" \
    --query-gpu=power.limit --format=csv,noheader,nounits | tr -d ' ')"
  local -r default_limit="$(nvidia-smi --id="${gpu_index}" \
    --query-gpu=power.default_limit --format=csv,noheader,nounits | tr -d ' ')"

  printf '\n%s\n' "-------------------------------------------------------"
  printf 'Samples : %s (every %ss)\n' "$(( $(wc -l < "${log_file}") - 1 ))" "${interval}"
  printf 'Log     : %s\n' "${log_file}"
  printf 'Cap     : %s W  (stock default: %s W)\n' "${limit}" "${default_limit}"

  # CSV fields: 1=timestamp 2=power.draw 3=power.limit 4=util 5=temp 6=clocks.sm 7=pcie.gen
  awk -F', *' -v limit="${limit}" '
    NR > 1 && $2 ~ /^[0-9.]+$/ {
      p = $2 + 0
      sum += p; n++
      if (p > max) max = p
      # "at the cap" = within 2% of it; the driver hovers rather than pinning
      if (p >= limit * 0.98) capped++

      t = $5 + 0
      tsum += t; tn++
      if (t > tmax) tmax = t
    }
    END {
      if (n == 0) { print "\nNo valid power samples."; exit }
      printf "Peak    : %.1f W\n", max
      printf "Average : %.1f W\n", sum / n
      printf "At cap  : %d of %d samples (%.1f%%)\n", capped, n, (capped * 100.0) / n
      if (tn > 0) {
        printf "GPU temp: %.0f C peak, %.0f C avg", tmax, tsum / tn
        # >83 C is where an Ada card starts thermal-throttling
        if (tmax >= 83) printf "  <-- THROTTLING RANGE"
        printf "\n"
      }
      print "-------------------------------------------------------"
      if (capped == 0) {
        printf "\n>> The cap was NEVER reached (peak %.1f W < cap %.1f W).\n", max, limit
        print   ">> A crash-free session therefore says NOTHING about whether"
        print   ">> the cap helps -- it was never doing anything. Raise the"
        print   ">> graphics settings, or test with a heavier load."
      } else if (capped * 100.0 / n < 5) {
        printf "\n>> The cap was reached in only %.1f%% of samples. Weak test:\n", (capped * 100.0) / n
        print   ">> the GPU is rarely power-limited here."
      } else {
        printf "\n>> The cap IS active (%.1f%% of samples at the limit).\n", (capped * 100.0) / n
        print   ">> This workload is genuinely power-capped, so a crash-free"
        print   ">> session is meaningful evidence."
      }
    }
  ' "${log_file}"
}

# }}} = FUNCTIONS =============================================================

# {{{ = MAIN ==================================================================

main() {
  declare -a CMD=()
  parse_args "$@"

  if ! command -v nvidia-smi >/dev/null 2>&1; then
    p_err "nvidia-smi not found"
    exit 1
  fi

  if [[ -z "${log_file}" ]]; then
    mkdir -p "${LOG_DIR}"
    log_file="${LOG_DIR}/$(date +%Y%m%d-%H%M%S).csv"
  fi

  printf 'Sampling GPU %s every %ss -> %s\n' "${gpu_index}" "${interval}" "${log_file}"
  printf 'Stop with Ctrl-C.\n\n'

  nvidia-smi --id="${gpu_index}" \
    --query-gpu=timestamp,power.draw,power.limit,utilization.gpu,temperature.gpu,clocks.sm,pcie.link.gen.current \
    --format=csv,nounits -l "${interval}" > "${log_file}" &
  local -r smi_pid=$!

  # Summarise on ANY exit path — Ctrl-C during a gaming session is the normal
  # one, and losing the summary there would defeat the point.
  trap 'kill "${smi_pid}" 2>/dev/null; summarise; exit 0' SIGINT SIGTERM EXIT

  if (( ${#CMD[@]} > 0 )); then
    "${CMD[@]}"
  else
    wait "${smi_pid}"
  fi
}

main "$@"

# }}} = MAIN ==================================================================
