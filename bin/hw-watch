#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# hw-watch: Log CPU + GPU load/temp/power, and report whether a power cap was
#           actually reached and whether thermals are genuinely a problem.

# set options
# -e omitted intentionally: the sampling loop must survive a transient sensor
# read failure rather than abandoning an in-progress gaming session.
set -o pipefail
set -o nounset
(( ${DEBUG_LVL:-0} >= 2 )) && set -o xtrace

# {{{ = CONSTANTS =============================================================

declare -r DEFAULT_INTERVAL=2
declare -r LOG_DIR="${XDG_STATE_HOME:-${HOME}/.local/state}/hw-watch"

# What reviews and "is 70C normal?" forum answers implicitly assume. Everything
# is normalised back to this so the numbers are comparable to the outside world.
declare -ri REF_AMBIENT=22

# Thermal limits for the hardware in this box.
declare -ri CPU_TJMAX=95      # Ryzen 9950X3D throttles here
declare -ri CPU_WARN=85
declare -ri GPU_THROTTLE=83   # Ada starts backing off around here

# }}} = CONSTANTS =============================================================

# {{{ = ARGUMENTS =============================================================

declare -i interval="${DEFAULT_INTERVAL}"
declare log_file=""
declare -i gpu_index=0
declare ambient=""            # room temperature, °C — enables normalisation
declare -a CMD=()

# }}} = ARGUMENTS =============================================================

# {{{ = FUNCTIONS =============================================================

usage() {
  cat <<EOF
Usage: hw-watch [OPTIONS] [--] [COMMAND..]

Sample CPU and GPU load, temperature and power to a CSV, then summarise.

Without COMMAND, samples until Ctrl-C. With COMMAND, samples while it runs.

Options:
  -a, --ambient C      Room temperature in C. Enables delta-over-ambient and
                       normalisation to a ${REF_AMBIENT}C reference — strongly recommended
  -i, --interval SEC   Sample interval (default: ${DEFAULT_INTERVAL})
  -o, --output FILE    CSV path (default: ${LOG_DIR}/<timestamp>.csv)
  -g, --gpu INDEX      GPU index (default: 0)
  -h, --help           This help

Why --ambient matters: every thermal benchmark and forum answer assumes ~${REF_AMBIENT}C
ambient. In a 30C room everything reads ~8C hotter and looks alarming while being
completely fine. Delta-over-ambient is the honest metric.

Why the power cap matters: a cap only proves anything if the card actually
REACHES it. If a game never draws more than the cap, a crash-free session says
nothing about whether the cap helps.

Examples:
  hw-watch --ambient 30           # start before the game; Ctrl-C after
  hw-watch -a 30 -i 1             # 1s resolution
  hw-watch -a 30 -- glxgears      # sample for the lifetime of a command

Background: docs/troubleshooting/gpu-xid79-bus-fall-off.md
            docs/troubleshooting/case-airflow-and-fans.md
EOF
}

p_err() { printf 'ERROR: %s\n' "$*" >&2; }

parse_args() {
  while (( $# > 0 )); do
    case "$1" in
      -a|--ambient)
        [[ -z "${2:-}" ]] && { p_err "--ambient requires a value"; exit 1; }
        ambient="$2"; shift 2 ;;
      -i|--interval)
        [[ -z "${2:-}" ]] && { p_err "--interval requires a value"; exit 1; }
        interval="$2"; shift 2 ;;
      -o|--output)
        [[ -z "${2:-}" ]] && { p_err "--output requires a value"; exit 1; }
        log_file="$2"; shift 2 ;;
      -g|--gpu)
        [[ -z "${2:-}" ]] && { p_err "--gpu requires a value"; exit 1; }
        gpu_index="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      --) shift; CMD=("$@"); break ;;
      -*) p_err "unknown option: $1"; usage >&2; exit 1 ;;
      *) CMD=("$@"); break ;;
    esac
  done
}

# {{{ - Sensors ---------------------------------------------------------------

# Locate the CPU hwmon dir once. Reading its sysfs files each tick costs ~1ms,
# versus spawning and parsing `sensors` every sample.
declare CPU_HWMON=""
find_cpu_hwmon() {
  local d name
  for d in /sys/class/hwmon/hwmon*; do
    name="$(cat "${d}/name" 2>/dev/null)" || continue
    if [[ "${name}" == "k10temp" || "${name}" == "coretemp" || "${name}" == "zenpower" ]]; then
      CPU_HWMON="${d}"
      return 0
    fi
  done
  return 1
}

# Map a temperature label (Tctl, Tccd1, ...) to its sysfs input file, once.
declare -A CPU_TEMP_FILE=()
map_cpu_temps() {
  [[ -z "${CPU_HWMON}" ]] && return 0
  local f label
  for f in "${CPU_HWMON}"/temp*_label; do
    [[ -e "${f}" ]] || continue
    label="$(cat "${f}" 2>/dev/null)" || continue
    CPU_TEMP_FILE["${label}"]="${f%_label}_input"
  done
}

# Whole degrees for a labelled sensor; empty if absent.
cpu_temp() {
  local -r file="${CPU_TEMP_FILE[$1]:-}"
  [[ -r "${file}" ]] || return 0
  printf '%d' "$(( $(cat "${file}") / 1000 ))"
}

# CPU utilisation % since the previous call, from /proc/stat.
#
# First line is: cpu user nice system idle iowait irq softirq steal ...
# so with read -ra: [0]=cpu [1]=user [2]=nice [3]=system [4]=idle [5]=iowait ...
declare -i PREV_IDLE=0 PREV_TOTAL=0
cpu_util() {
  local -a f=()
  read -ra f < /proc/stat

  local -i idle=$(( f[4] + f[5] ))   # idle + iowait
  local -i total=0 i
  for (( i = 1; i < ${#f[@]}; i++ )); do
    total+=$(( f[i] ))
  done

  local -i d_idle=$(( idle - PREV_IDLE ))
  local -i d_total=$(( total - PREV_TOTAL ))
  PREV_IDLE=${idle}
  PREV_TOTAL=${total}

  (( d_total <= 0 )) && { printf '0'; return 0; }
  printf '%d' $(( 100 * (d_total - d_idle) / d_total ))
}

# }}} - Sensors ---------------------------------------------------------------

sample_loop() {
  printf 'timestamp,cpu_util,cpu_tctl,cpu_ccd1,cpu_ccd2,gpu_power,gpu_util,gpu_temp,gpu_clock\n' \
    > "${log_file}"

  cpu_util >/dev/null   # prime the /proc/stat delta

  local gpu
  while :; do
    gpu="$(nvidia-smi --id="${gpu_index}" \
      --query-gpu=power.draw,utilization.gpu,temperature.gpu,clocks.sm \
      --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')"
    [[ -z "${gpu}" ]] && gpu=",,,"

    printf '%s,%s,%s,%s,%s,%s\n' \
      "$(date +%H:%M:%S)" \
      "$(cpu_util)" \
      "$(cpu_temp Tctl)" \
      "$(cpu_temp Tccd1)" \
      "$(cpu_temp Tccd2)" \
      "${gpu}" >> "${log_file}"

    sleep "${interval}"
  done
}

# Ctrl-C fires SIGINT *and then* EXIT, so without this guard the summary prints
# twice on the one path that matters most (stopping after a gaming session).
declare -i SUMMARISED=0
summarise() {
  (( SUMMARISED )) && return 0
  SUMMARISED=1

  [[ -s "${log_file}" ]] || { printf '\nNo samples collected.\n'; return 0; }

  local limit default_limit
  limit="$(nvidia-smi --id="${gpu_index}" --query-gpu=power.limit \
    --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')"
  default_limit="$(nvidia-smi --id="${gpu_index}" --query-gpu=power.default_limit \
    --format=csv,noheader,nounits 2>/dev/null | tr -d ' ')"
  : "${limit:=0}" "${default_limit:=0}"

  printf '\n'
  awk -F, \
      -v limit="${limit}" -v deflimit="${default_limit}" \
      -v ambient="${ambient}" -v ref="${REF_AMBIENT}" \
      -v tjmax="${CPU_TJMAX}" -v cpuwarn="${CPU_WARN}" -v gputhr="${GPU_THROTTLE}" \
      -v logf="${log_file}" -v iv="${interval}" '
    NR > 1 {
      n++
      if ($2 != "") { cu_s += $2; if ($2 + 0 > cu_m) cu_m = $2 }
      if ($3 != "") { ct_s += $3; if ($3 + 0 > ct_m) ct_m = $3; ct_n++ }
      if ($4 != "") { c1_s += $4; if ($4 + 0 > c1_m) c1_m = $4; c1_n++ }
      if ($5 != "") { c2_s += $5; if ($5 + 0 > c2_m) c2_m = $5; c2_n++ }
      if ($6 != "") {
        gp_s += $6; if ($6 + 0 > gp_m) gp_m = $6; gp_n++
        if (limit > 0 && $6 >= limit * 0.98) capped++
      }
      if ($7 != "") { gu_s += $7; if ($7 + 0 > gu_m) gu_m = $7; gu_n++ }
      if ($8 != "") { gt_s += $8; if ($8 + 0 > gt_m) gt_m = $8; gt_n++ }
    }
    END {
      if (n == 0) { print "No valid samples."; exit }
      line = "---------------------------------------------------------------"
      cmax = (c1_m + 0 > c2_m + 0 ? c1_m : c2_m)

      print line
      printf "Samples : %d (every %ss)\nLog     : %s\n", n, iv, logf
      if (ambient != "") printf "Ambient : %s C (normalising to a %d C reference)\n", ambient, ref
      print line

      printf "CPU  util : %3d%% peak, %3d%% avg\n", cu_m, cu_s / n
      if (c1_n) {
        printf "CPU  temp : %3d C peak (CCD), %3d C peak (Tctl)", cmax, ct_m
        if (ambient != "") printf "  =>  %d C @%dC ambient", cmax - ambient + ref, ref
        printf "\n"
      }
      if (gp_n) {
        printf "GPU  power: %3d W peak, %3d W avg   (cap %d W, stock %d W)\n", \
          gp_m, gp_s / gp_n, limit, deflimit
        printf "GPU  util : %3d%% peak, %3d%% avg\n", gu_m, (gu_n ? gu_s / gu_n : 0)
        printf "GPU  temp : %3d C peak, %3d C avg", gt_m, (gt_n ? gt_s / gt_n : 0)
        if (ambient != "") printf "  =>  %d C @%dC ambient", gt_m - ambient + ref, ref
        printf "\n"
        printf "GPU  @cap : %d of %d samples (%.1f%%)\n", capped, gp_n, (capped * 100.0) / gp_n
      }
      print line

      # --- Was the power-cap test even valid? ---
      if (gp_n && limit > 0 && limit < deflimit) {
        if (capped == 0) {
          printf "\n[CAP] NEVER REACHED (peak %d W < cap %d W).\n", gp_m, limit
          print   "      A crash-free session says NOTHING about the cap -- it was"
          print   "      never doing anything. Raise settings or test a heavier load."
        } else if (capped * 100.0 / gp_n < 5) {
          printf "\n[CAP] Reached in only %.1f%% of samples. Weak test.\n", (capped * 100.0) / gp_n
        } else {
          printf "\n[CAP] ACTIVE (%.1f%% of samples at the limit).\n", (capped * 100.0) / gp_n
          print   "      This workload is genuinely power-capped, so a crash-free"
          print   "      session is meaningful evidence."
        }
      }

      # --- Are thermals actually a problem? ---
      if (c1_n || gt_n) {
        hot = 0
        if (c1_n && cmax + 0 >= cpuwarn) hot = 1
        if (gt_n && gt_m + 0 >= gputhr)  hot = 1

        if (hot) {
          print "\n[THERMAL] Running hot:"
          if (c1_n && cmax + 0 >= tjmax)
            printf "      CPU hit %d C -- AT Tjmax (%d C). Throttling.\n", cmax, tjmax
          else if (c1_n && cmax + 0 >= cpuwarn)
            printf "      CPU peaked at %d C (warn from %d C).\n", cmax, cpuwarn
          if (gt_n && gt_m + 0 >= gputhr)
            printf "      GPU peaked at %d C -- Ada throttles from ~%d C.\n", gt_m, gputhr
          if (ambient != "" && ambient + 0 > ref)
            printf "      NOTE: ambient is %d C ABOVE the %d C reference. At %d C ambient\n            the CPU would be ~%d C. Consider cooling the ROOM before\n            buying case fans.\n", \
              ambient - ref, ref, ref, cmax - ambient + ref
        } else {
          print "\n[THERMAL] Fine. Nothing is close to throttling."
          if (ambient != "" && ambient + 0 > ref)
            printf "      And that is at %s C ambient -- %d C above the %d C that every\n      review and forum answer assumes. Thermals are NOT a limiting\n      factor here; the room is just hot.\n", \
              ambient, ambient - ref, ref
        }
      }
    }
  ' "${log_file}"
}

# }}} = FUNCTIONS =============================================================

# {{{ = MAIN ==================================================================

main() {
  parse_args "$@"

  command -v nvidia-smi >/dev/null 2>&1 \
    || printf 'WARNING: nvidia-smi not found — GPU columns will be empty\n' >&2

  if find_cpu_hwmon; then
    map_cpu_temps
  else
    printf 'WARNING: no CPU temperature sensor found (k10temp/coretemp)\n' >&2
  fi

  if [[ -z "${log_file}" ]]; then
    mkdir -p "${LOG_DIR}"
    log_file="${LOG_DIR}/$(date +%Y%m%d-%H%M%S).csv"
  fi

  printf 'Sampling every %ss -> %s\n' "${interval}" "${log_file}"
  [[ -z "${ambient}" ]] \
    && printf 'TIP: pass --ambient <room C> so temperatures can be normalised.\n'
  printf 'Stop with Ctrl-C.\n'

  sample_loop &
  local -r loop_pid=$!

  # Summarise on ANY exit path — Ctrl-C after a gaming session is the normal one,
  # and losing the summary there would defeat the entire point of the tool.
  trap 'kill "${loop_pid}" 2>/dev/null; summarise; exit 0' SIGINT SIGTERM EXIT

  if (( ${#CMD[@]} > 0 )); then
    "${CMD[@]}"
  else
    wait "${loop_pid}"
  fi
}

main "$@"

# }}} = MAIN ==================================================================
