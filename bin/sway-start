#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# Start Sway with environment tuned to the active GPU driver. Auto-detects
# the proprietary Nvidia driver and, if active, adds the required launch
# flag and env vars; override the detection with --nvidia / --no-nvidia.

set -euo pipefail

# shellcheck disable=SC2155
declare -r SCRIPT_FILE="$(basename "$0")"

# Use ~/.xsession.log for backward compatibility, e.g. with conky configs
declare -r LOG_FILE="$HOME/.xsession.log"

p_err() { printf '\033[31mERROR\033[0m: %s\n' "$*" >&2; }

p_usg() {
  cat <<EOF
Usage: ${SCRIPT_FILE} [OPTIONS] [-- SWAY_ARGS...]

Start Sway with environment tuned to the active GPU driver.

Options:
  --nvidia      Force Nvidia proprietary-driver mode (--unsupported-gpu,
                software cursor), regardless of auto-detection
  --no-nvidia   Force plain mode, even if the Nvidia driver is detected
  -h, --help    Show this help message and exit

Auto-detection:
  Nvidia mode is enabled automatically when the proprietary 'nvidia' kernel
  module is loaded (checked via /sys/module/nvidia).

Log file: ${LOG_FILE}
EOF
}

# Return 0 if the proprietary Nvidia kernel module is currently loaded.
nvidia_active() {
  [[ -d /sys/module/nvidia ]]
}

main() {
  local nvidia_mode=""
  local -a sway_args=()

  while (( $# > 0 )); do
    case "$1" in
      --nvidia)    nvidia_mode="true" ;;
      --no-nvidia) nvidia_mode="false" ;;
      -h|--help)   p_usg; exit 0 ;;
      --)
        shift
        sway_args+=("$@")
        break
        ;;
      -*)
        p_err "unknown option: $1"
        p_usg >&2
        exit 1
        ;;
      *)
        sway_args+=("$1")
        ;;
    esac
    shift
  done

  if [[ -z "${nvidia_mode}" ]]; then
    if nvidia_active; then nvidia_mode="true"; else nvidia_mode="false"; fi
  fi

  # Wayland-native defaults (https://github.com/swaywm/sway/wiki/Running-programs-natively-under-wayland)
  # Qt5/6: force Wayland backend (XDG_SESSION_TYPE=wayland is set by sway, but being explicit is cleaner)
  export QT_QPA_PLATFORM=wayland
  # Java: required for correct rendering under Xwayland (reparenting WM workaround)
  export _JAVA_AWT_WM_NONREPARENTING=1
  # Required for XDG desktop portal backend selection (portals, file pickers, etc.)
  export XDG_CURRENT_DESKTOP=sway

  if [[ "${nvidia_mode}" == "true" ]]; then
    # Nvidia: software cursor (no hardware cursor support with proprietary drivers)
    export WLR_NO_HARDWARE_CURSORS=1
    sway_args=(--unsupported-gpu "${sway_args[@]}")
  fi

  # Log to file for debugging and monitoring (e.g. conky). Overwrite instead
  # of append to avoid unbounded growth; no rotation needed.
  exec > >(tee "${LOG_FILE}") 2>&1
  exec sway "${sway_args[@]}"
}

main "$@"
