#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# Recursively find media files and play them with mpv.

# set options
set -o errtrace
#set -o errexit
set -o pipefail
set -o nounset
(( ${DEBUG_LVL:-0} >= 2 )) && set -o xtrace
IFS=$'\t\n\0'

# traps
# shellcheck disable=SC2154
trap 'rc=$?; \
     printf "ERROR(%s) in %s:%s\n  -> %s\n  -> %s\n" "${rc}" \
            "${0:-N/A}" "${LINENO:-N/A}" "${FUNCNAME[@]:-N/A}" \
            "${BASH_COMMAND:-N/A}"; \
     exit $rc' ERR
trap 'printf "\nINTERRUPT\n"; exit 1' SIGINT SIGTERM

# Logging
#p_msg() { printf '%s\n' "$*"; }
#p_nfo() { printf '\033[32mINFO\033[0m %s\n' "$*"; }
#p_war() { printf '\033[33mWARNING\033[0m %s\n' "$*" >&2; }
p_err() { printf '\033[31mERROR\033[0m: %s\n' "$*" >&2; }
#p_dbg() { (( "${1:-0}" <= "${DEBUG_LVL:-0}" )) && printf '\033[36mDEBUG\033[0m: %s\n' "${*:2}" >&2 || true; }

# Usage
p_usg() { printf 'Usage: %s  [OPTION]... DIR... [-a MPV_ARG]...\n' "$(basename "$0")"; }
p_hlp() {
  p_usg
  cat <<EOF

Options:
  -m, --match P    Filter files by regex pattern (full file path)
                   (default: ".*\.\(avi\|mkv\|mp4\|webm\)")
  -s, --sort A     Sort arg, e.g. -R for random (default: -g, see: "man sort")
  -r, --recursive  Find videos in subdirectories (default: off)
  -i, --index X    Skip the first X search results (default: 0)
  -n, --noact      Don't play the search result, send it to stdout instead

  -nr, --no-resume Equivalent to adding mpv argument --no-resume-playback

  -h, --help       Show this help

MPV Arguments:
  -a, --mpv-args   All arguments after this one are forwarded to mpv

Examples:
  # play all videos found in . and below in random order
  $(basename "$0") -r -s -R
  # play all webm files found in /video skipping the first 10 files
  # deactivating mpv's resume-playback feature
  $(basename "$0") /video -m ".*\.webm" -i 10 -a --no-resume-playback
EOF
}

# TODO find a way to stop the playback loop when exiting mpv but ignoring errors
# MPV Config:
#   # to stop playback after quitting mpv use the exit code 100 in mpv
#   # if this is not done, quitting mpv will continue the loop (not desirable)
#   # input.conf:
#   ESC quit 100
#   q quit-watch-later 100

# arguments
declare regex=".*\.\(avi\|mkv\|mp4\|webm\)"
declare tailn=0
declare recursive=false
declare sort=-g
declare noact=false
declare noresume=false
declare -a dirs
declare -a mpv_args

# parse arguments
parse_args() {
  while [[ -n "${1:-}" ]]; do
    case "$1" in
      -i|--index)
        if [[ -z "${2:-}" ]]; then
          p_err "missing value for argument --index"
          exit 1
        fi
        tailn="$(($2+1))"
        shift 2
        ;;
      -r|--recursive)
        recursive=true
        shift
        ;;
      -m|--match)
        if [[ -z "${2:-}" ]]; then
          p_err "missing value for argument --match"
          exit 1
        fi
        regex="$2"
        shift 2
        ;;
      -s|--sort)
        if [[ -z "${2:-}" ]]; then
          p_err "missing value for argument --sort"
          exit 1
        fi
        sort="$2"
        shift 2
        ;;
      -n|--noact)
        noact=true
        shift
        ;;
      -a|--mpv-args)
        shift
        break # all args after this are treated as mpv args
        ;;
      -nr|--no-resume)
        noresume=true
        shift
        ;;
      -h|--help)
        p_hlp
        exit 0
        ;;
      *)
        if [[ -z "${1:-}" ]]; then
          p_usg
          exit 1
        fi
        if [[ ! -d "$1" ]]; then
          p_err "no such directory or unknown argument: $1"
          exit 1
        fi
        dirs+=("$1"); shift
        ;;
    esac
  done
  # default directory .
  [[ -z "${dirs:-}" ]] && dirs=(.)
  # treat all remaining args as mpv args
  mpv_args=("$@")
  if ${noresume}; then
    mpv_args+=(--no-resume-playback)
  fi
}

mpvfind() {
  local -a maxdepth=()
  ${recursive} || maxdepth=(-maxdepth 1)
  # shellcheck disable=SC2015
  find "${dirs[@]}" "${maxdepth[@]}" \
       -regex "$regex" \
    | sort "$sort" \
    | tail -n +"${tailn}" \
    | (${noact} && cat || tr '\n' '\0' | xargs -0 -n 10000 mpv "${mpv_args[@]}")
}

main() {
  parse_args "$@"
  mpvfind
}

main "$@"
