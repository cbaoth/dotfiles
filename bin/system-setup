#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# system-setup: Run idempotent system setup modules from the dotfiles repo.

# set options
# -e omitted intentionally: a failing module must not abort the whole run,
# it is reported and the next module still gets its chance.
set -o pipefail
set -o nounset
(( ${DEBUG_LVL:-0} >= 2 )) && set -o xtrace

# traps
trap 'printf "\nINTERRUPT\n"; exit 1' SIGINT SIGTERM

# {{{ = CONSTANTS =============================================================

# Resolve the repo even when invoked via the ~/bin symlink that dotfiles-link
# creates (readlink -f follows it back into the repo).
ST_BIN_PATH="$(cd "$(dirname "$(readlink -f "$0")")" && pwd -P)"
declare -r ST_BIN_PATH
declare -r ST_REPO_DIR="${ST_BIN_PATH%/bin}"
declare -r ST_SETUP_DIR="${ST_REPO_DIR}/setup"
declare -r ST_MODULE_DIR="${ST_SETUP_DIR}/modules"
export ST_SETUP_DIR ST_REPO_DIR

declare -ra ST_PROFILES=(desktop server wsl)

if [[ ! -d "${ST_MODULE_DIR}" ]]; then
  printf 'ERROR: module dir not found: %s\n' "${ST_MODULE_DIR}" >&2
  exit 1
fi

# Must be sourced at top level: setup-lib.sh uses `declare -r`, which inside a
# function would create unset function-local shadows instead of globals.
# shellcheck source=../setup/lib/setup-lib.sh
source "${ST_SETUP_DIR}/lib/setup-lib.sh"

# }}} = CONSTANTS =============================================================

# {{{ = ARGUMENTS =============================================================

declare -i ST_DRY_RUN=0
declare -i opt_list=0
declare -i opt_yes=0
declare profile=""
declare -a requested_modules=()

# }}} = ARGUMENTS =============================================================

# {{{ = FUNCTIONS =============================================================

usage() {
  cat <<EOF
Usage: system-setup [OPTIONS] [MODULE..]

Run idempotent system setup modules. Re-running is safe and is expected to
report zero changes — that is the contract every module must honour.

Options:
  -l, --list             List available modules and exit
  -n, --dry-run          Print what would change; change nothing
  -p, --profile PROFILE  Run all modules matching PROFILE
                         (${ST_PROFILES[*]}, or 'auto' to detect)
  -y, --yes              Do not prompt before applying changes
  -h, --help             This help

Arguments:
  MODULE                 One or more module names (with or without the .sh
                         suffix), e.g. '20-flatpak'. Overrides --profile.

Examples:
  system-setup --list
  system-setup --dry-run --profile desktop
  system-setup --profile auto
  system-setup 20-flatpak 30-docker

Modules live in setup/modules/, package lists in setup/packages/.
Docs: docs/setup/
EOF
}

# Print "name<TAB>desc<TAB>profiles" for every module, sourcing each in a
# subshell so module metadata can never leak between modules.
module_meta() {
  local -r module_file="$1"
  (
    MODULE_DESC="" MODULE_PROFILES=() MODULE_DOC=""
    # shellcheck disable=SC1090  # module path is discovered at runtime
    source "${module_file}" >/dev/null 2>&1 || true
    printf '%s\t%s\t%s\t%s\n' \
      "$(basename "${module_file}" .sh)" \
      "${MODULE_DESC:-(no description)}" \
      "${MODULE_PROFILES[*]:-all}" \
      "${MODULE_DOC:-}"
  )
}

list_modules() {
  local module_file name desc profiles doc
  printf '%sAvailable modules%s (setup/modules/)\n\n' "${ST_C_BOLD}" "${ST_C_RESET}"
  for module_file in "${ST_MODULE_DIR}"/*.sh; do
    [[ -f "${module_file}" ]] || continue
    IFS=$'\t' read -r name desc profiles doc < <(module_meta "${module_file}")
    printf '  %s%-20s%s %s\n' "${ST_C_GREEN}" "${name}" "${ST_C_RESET}" "${desc}"
    printf '  %-20s %sprofiles: %s%s\n' "" "${ST_C_DIM}" "${profiles}" "${ST_C_RESET}"
    [[ -n "${doc}" ]] \
      && printf '  %-20s %sdocs: %s%s\n' "" "${ST_C_DIM}" "${doc}" "${ST_C_RESET}"
  done
  printf '\n'
}

# Does MODULE_PROFILES contain the requested profile? An empty/unset
# MODULE_PROFILES means "every profile".
module_matches_profile() {
  local -r module_file="$1"
  local -r want="$2"
  local name desc profiles doc

  IFS=$'\t' read -r name desc profiles doc < <(module_meta "${module_file}")
  [[ "${profiles}" == "all" ]] && return 0
  [[ " ${profiles} " == *" ${want} "* ]]
}

# Run one module in a subshell and report its change counts back via stdout.
run_module() {
  local -r module_file="$1"
  local -r name="$(basename "${module_file}" .sh)"

  local counts rc
  counts="$(
    # A subshell already inherits the st::* functions and ST_DRY_RUN from the
    # parent; re-sourcing setup-lib.sh here would only trip over its readonly
    # colour vars. Just reset the per-module counters.
    # shellcheck disable=SC2034  # read by the st::* helpers in setup-lib.sh
    ST_CHANGED=0 ST_SKIPPED=0 ST_APT_UPDATED=0

    MODULE_DESC="" MODULE_PROFILES=() MODULE_DOC=""
    # shellcheck source=/dev/null
    source "${module_file}"

    st::hdr "${name}${MODULE_DESC:+ — ${MODULE_DESC}}" >&2

    if ! declare -f module_run >/dev/null; then
      st::err "module defines no module_run(): ${module_file}" >&2
      exit 2
    fi

    module_run >&2 || { st::err "module failed: ${name}" >&2; exit 1; }

    # the only thing on stdout: the counters, for the parent to total up
    printf '%s %s' "${ST_CHANGED}" "${ST_SKIPPED}"
  )"
  rc=$?

  local -i changed=0 skipped=0
  read -r changed skipped <<<"${counts:-0 0}"
  printf '%s %s %s' "${rc}" "${changed}" "${skipped}"
}

# }}} = FUNCTIONS =============================================================

# {{{ = ARGUMENT PARSING ======================================================

parse_args() {
  while (( $# > 0 )); do
    case "$1" in
      -l|--list)     opt_list=1; shift ;;
      -n|--dry-run)  ST_DRY_RUN=1; shift ;;
      -y|--yes)      opt_yes=1; shift ;;
      -p|--profile)
        if [[ -z "${2:-}" ]]; then
          printf 'ERROR: --profile requires a value\n' >&2
          exit 1
        fi
        profile="$2"; shift 2
        ;;
      -h|--help)     usage; exit 0 ;;
      --)            shift; requested_modules+=("$@"); break ;;
      -*)
        printf 'ERROR: unknown option: %s\n\n' "$1" >&2
        usage >&2
        exit 1
        ;;
      *)             requested_modules+=("${1%.sh}"); shift ;;
    esac
  done

  if [[ "${profile}" == "auto" ]]; then
    profile="$(st::guess_profile)"
    st::msg "detected profile: ${profile}"
  fi

  if [[ -n "${profile}" ]] && [[ ! " ${ST_PROFILES[*]} " == *" ${profile} "* ]]; then
    printf 'ERROR: unknown profile: %s (known: %s)\n' \
      "${profile}" "${ST_PROFILES[*]}" >&2
    exit 1
  fi
}

# }}} = ARGUMENT PARSING ======================================================

# {{{ = MAIN ==================================================================

main() {
  parse_args "$@"

  if (( opt_list )); then
    list_modules
    exit 0
  fi

  # Build the run set: explicit modules win over --profile.
  local -a to_run=()
  local module_file name
  if (( ${#requested_modules[@]} > 0 )); then
    for name in "${requested_modules[@]}"; do
      module_file="${ST_MODULE_DIR}/${name}.sh"
      if [[ ! -f "${module_file}" ]]; then
        st::err "no such module: ${name} (try --list)"
        exit 1
      fi
      to_run+=("${module_file}")
    done
  elif [[ -n "${profile}" ]]; then
    for module_file in "${ST_MODULE_DIR}"/*.sh; do
      [[ -f "${module_file}" ]] || continue
      module_matches_profile "${module_file}" "${profile}" && to_run+=("${module_file}")
    done
  else
    printf 'ERROR: nothing to do — pass MODULE names or --profile\n\n' >&2
    usage >&2
    exit 1
  fi

  if (( ${#to_run[@]} == 0 )); then
    st::war "no modules match profile: ${profile}"
    exit 0
  fi

  # Confirm before mutating the system, unless --yes / --dry-run.
  if (( ! ST_DRY_RUN && ! opt_yes )); then
    printf '\nAbout to run %d module(s) on this machine:\n' "${#to_run[@]}"
    for module_file in "${to_run[@]}"; do
      printf '  - %s\n' "$(basename "${module_file}" .sh)"
    done
    printf '\nContinue? [y/N] '
    local reply=""
    read -r reply
    if [[ ! "${reply}" =~ ^[Yy]$ ]]; then
      printf 'Aborted.\n'
      exit 0
    fi
  fi

  (( ST_DRY_RUN )) && st::war "DRY RUN — nothing will be changed"

  local -i total_changed=0 total_skipped=0 failed=0
  local rc changed skipped
  for module_file in "${to_run[@]}"; do
    read -r rc changed skipped < <(run_module "${module_file}")
    (( total_changed += changed ))
    (( total_skipped += skipped ))
    (( rc != 0 )) && (( failed++ ))
  done

  # The summary is the idempotency contract made visible: a second run of the
  # same modules must print "0 changed".
  printf '\n%s==>%s %s%d changed%s, %d already correct' \
    "${ST_C_BLUE}" "${ST_C_RESET}" \
    "${ST_C_BOLD}" "${total_changed}" "${ST_C_RESET}" "${total_skipped}"
  (( failed > 0 )) \
    && printf ', %s%d module(s) failed%s' "${ST_C_RED}" "${failed}" "${ST_C_RESET}"
  printf '\n'

  (( ST_DRY_RUN && total_changed > 0 )) \
    && printf '%sRe-run without --dry-run to apply.%s\n' "${ST_C_DIM}" "${ST_C_RESET}"

  (( failed > 0 )) && exit 1
  return 0
}

main "$@"

# }}} = MAIN ==================================================================
