#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# Download to a dynamic filename using aria2c.

# set options
set -o errtrace
#set -o errexit
set -o pipefail
set -o nounset
(( ${DEBUG_LVL:-0} >= 2 )) && set -o xtrace
IFS=$'\t\n\0'

# traps
#trap 'rc=$?; \
#      printf "ERROR(%s) in %s:%s\n  -> %s\n  -> %s\n" "${rc}" \
#             "${0:-N/A}" "${LINENO:-N/A}" "${FUNCNAME[@]:-N/A}" \
#             "${BASH_COMMAND:-N/A}"; \
#      exit $rc' ERR
trap 'printf "\nINTERRUPT\n"; exit 1' SIGINT SIGTERM
#trap 'rc=$?; printf "EXIT(%s)\n" "$rc"; exit $rc' EXIT

usage() {
  cat <<EOF
Usage: $(basename "$0") [-r] URL.. ARIA2C_ARG.."
EOF
}

get_url_from_file() {
  tr '+' '/' <<<"$1"
}

get_file_from_url() {
  sed -E 's/^https?:\/\///g;s/\/+$//g;s/\//+/g' <<<"$1"
}

main() {
  local rev=false
  if [[ "${1:-}" = "-r" ]]; then
    rev=true
    shift
  fi

  if [[ -z "${1:-}" || "${1:-}" = -* ]]; then
    usage
    exit 1
  fi
  local -a urls outfiles
  while [[ -n "${1:-}" && "${1:-}" != -* ]]; do
    if ${rev}; then
      urls+=("$(get_url_from_file "$1")")
      outfiles+=("$1")
    else
      urls+=("$1")
      outfiles+=("$(get_file_from_url "$1")")
    fi
    shift
  done
  if [[ -z "${urls[*]}" ]]; then
    usage
    exit 1
  fi
  for ((i=0; i<${#urls[@]}; i++)); do
    local url="${urls[$i]}"
    local outfile="${outfiles[$i]}"
    if ${rev}; then
        printf "Trying to re-download [%s] from presumed address [https://%s]\n" "$outfile" "$url"
        if ! aria2c -o "${outfile}" "https://${url}" "$@"; then
          printf "Attempt to re-download via https failed, trying http [http://%s]\n" "$url"
          aria2c -o "${outfile}" "http://${url}" "$@"
        fi
    else
      aria2c -o "${outfile}" "${urls[$i]}" "$@"
    fi
  done
}

main "$@"
