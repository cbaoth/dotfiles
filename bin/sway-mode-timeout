#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash
#
# Auto-exit the current Sway mode after a delay. Only one timer runs at a time;
# entering a new mode cancels the previous timer via a pidfile.

set -euo pipefail

# shellcheck disable=SC2155
declare -r SCRIPT_FILE="$(basename "$0")"
declare -r PIDFILE="${XDG_RUNTIME_DIR:-/tmp}/sway-mode-timeout.pid"

p_err() { printf '\033[31mERROR\033[0m: %s\n' "$*" >&2; }

p_usg() {
  cat <<EOF
Usage: ${SCRIPT_FILE} [TIMEOUT_SECS]

Auto-exit the current Sway mode after TIMEOUT_SECS (default: 5). Only one
timer runs at a time; entering a new mode cancels the previous timer.

Options:
  -h, --help   Show this help message and exit
EOF
}

main() {
  local -r timeout="${1:-5}"

  case "${timeout}" in
    -h|--help) p_usg; exit 0 ;;
  esac

  if [[ ! "${timeout}" =~ ^[0-9]+$ ]]; then
    p_err "TIMEOUT_SECS must be a non-negative integer: '${timeout}'"
    p_usg >&2
    exit 1
  fi

  if [[ -f "${PIDFILE}" ]]; then
    kill "$(cat "${PIDFILE}")" 2>/dev/null || true
  fi
  printf '%s\n' "$$" > "${PIDFILE}"

  sleep "${timeout}"
  rm -f "${PIDFILE}"

  local current
  current=$(swaymsg -t get_binding_state | jq -r '.name')
  [[ "${current}" != "default" ]] && swaymsg mode default
  return 0
}

main "$@"
