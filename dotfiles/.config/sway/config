# {{{ = Variables ============================================================
# default mod key (Super_L/Super_R keys, usually the Windows key)
set $mod Mod4

# alternative mod key (Hyper_L, ISO key between Left Shift and Z on ISO keyboards)
# Requires ~/.config/xkb/symbols/custom to map <LSGT> to Hyper_L on Mod3, e.g.:
# ----
# xkb_symbols "basic" {
#   include "us(colemak)"
#   name[Group1] = "English (Colemak + ISO mod)";
#   key <LSGT> { [ Hyper_L, Hyper_L ] };
#   modifier_map Mod3 { Hyper_L };
# }
# ----
# https://wiki.archlinux.org/title/Sway#Change_modifier_to_CapsLock_and_keep_Super
set $hyper Mod3

# default $mod+x chord mapping mod keys, e.g. via /etc/keyd/default.conf:
# ----
# [meta_chord]
# a = M-C-A-S-a
# b = M-C-A-S-b
# c = M-C-A-S-c
# ...
# [meta]
# x = timeout(oneshot(meta_chord), 1000, M-x)
# ----
# FIXE dosen't work this way
#set $cmods          $mod+Ctrl+Mod1+Shift

# Directional navigation keys
set $left            q
set $right           w
set $up              f
set $down            p

# Directional navigation keys (vim-like hjkl)
#set $left           h
#set $down           j
#set $up             k
#set $right          l

# SWAY: preferred Wayland-native terminal (foot is lightweight and native)
# Alternatives: alacritty, kitty, wezterm, gnome-terminal
set $term            foot
set $termfloat       foot --window-size-chars=120x50 --app-id=swayfloat

# $FLOAT: used in for_window rules for windows that should always be floating+borderless
# (not for interactive toggle - use `sway-wstate float` for that via $mod+Alt+t)
set $FLOAT           floating enable, border normal 0

# commands to enable/disable sticky with border indicator
# sticky floating windows get border normal 2 to distinguish them visually
set $STICK_AND_FLOAT sticky enable,  floating enable, border normal 2
set $UNSTICK         sticky disable, floating enable, border normal 0

# workspace numbers and names
set $ws1             "1:#1 Main"
set $ws2             "2:#2 Web"
set $ws3             "3:#3 Devel"
set $ws4             "4:#4 Create"
set $ws5             "5:#5 Gaming"
set $ws6             "6:#6 Fullscreen"
set $ws7             "7:#7 Misc"
set $ws8             "8:#8 Misc"
set $ws9             "9:#9 Misc"
set $ws10            "10:#10 System"
