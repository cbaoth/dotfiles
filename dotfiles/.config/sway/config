# Main mod key (Super_L/Super_R keys, usually the Windows key)
set $mod Mod4

# Alt keys (Alt_L/Alt_R) are Mod1, just use "Alt" in bindssym.
# set $alt   Mod1

# AltGr (ISO_Level3_Shift) is Mod5
set $altgr Mod5

# Hyper mod key (Hyper_L, ISO key between Left Shift and Z on ISO keyboards)
set $hyper Mod3
# Requires ~/.config/xkb/symbols/custom to map <LSGT> to Hyper_L on Mod3, e.g.:
# ----
# xkb_symbols "basic" {
#   include "us(colemak)"
#   name[Group1] = "Colemak (US)";
#   key <LSGT> { [ Hyper_L, Hyper_L ] };
#   modifier_map Mod3 { <LSGT> };
