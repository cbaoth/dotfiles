# {{{ - Meta Modes -----------------------------------------------------------
# mod-x: window mode
set $mode_meta           Window mode | General: (c)lose window | Resize: $left/$right/$down/$up or Left/Right/Down/Up arrow keys
bindsym $mod+x           mode "$mode_meta"; exec sway-mode-timeout $mode_timeout_secs
mode "$mode_meta" {
    bindsym c            kill, mode "default"

    bindsym $left        resize shrink width  100 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym $right       resize grow   width  100 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym $up          resize grow   height 100 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym $down        resize shrink height 100 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Shift+$left  resize shrink width   10 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Shift+$right resize grow   width   10 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Shift+$up    resize grow   height  10 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Shift+$down  resize shrink height  10 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs

    bindsym Left         resize shrink width  100 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Right        resize grow   width  100 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Up           resize grow   height 100 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Down         resize shrink height 100 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Shift+Left   resize shrink width   10 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Shift+Right  resize grow   width   10 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Shift+Up     resize grow   height  10 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs
    bindsym Shift+Down   resize shrink height  10 px; mode "$mode_resize"; exec sway-mode-timeout $mode_timeout_secs

    bindsym Return       mode "default"
    bindsym Escape       mode "default"
}

# mod-ESC: system mode
# SWAY: i3-nagbar → swaynag, i3-msg → swaymsg, dm-tool lock → swaylock
#       xsuspend → swaylock -f && systemctl suspend
#       restart  → reload  (sway has no in-place restart equivalent)
set $mode_system Sway: [l]ock, reload-[c]onfigure, e[X]it \
        | Awake: keep-[a]wake (30min [A]uto-off) \
        | System: [S]uspend, [H]ibernate, [R]eboot, shut[D]own
#       | PulseAudio: switch card [p]rofile, restart [P]ipeWire
bindsym $mod+Escape mode "$mode_system"; exec sway-mode-timeout $mode_timeout_secs
mode "$mode_system" {
    # Sway:
    # l: lock screen
    bindsym l                exec swaylock -c 000000, mode "default"
    # c: reload the configuration file (sway has no restart, reload is equivalent)
    bindsym c                reload, mode "default"
    # X: exit sway
    bindsym Shift+x          mode "default"; exec swaynag -t warning \
                                 -m 'Do you really want to exit Sway?' \
                                 -b 'Exit Sway' 'swaymsg exit'

    # Awake:
    # a: toggle sway-awake (manual keep-awake)
    bindsym a                mode "default"; exec sway-awake toggle
    # A: with 30-min auto-off.
    bindsym Shift+a          mode "default"; exec sway-awake toggle 30m
    # Indicator + click-toggle also available via the waybar custom/sway-awake module.

    # System:
    # S: lock screen + suspend
    bindsym Shift+s          mode "default"; exec swaylock -f -c 000000 && systemctl suspend
    # H: lock screen + hibernate
    bindsym Shift+h          mode "default"; exec swaylock -f -c 000000 && systemctl hibernate
    # Alt+r: reboot
    bindsym Shift+r          mode "default"; exec swaynag -t warning \
                                 -m 'Do you really want to reboot the system?' \
                                 -b 'Reboot' 'systemctl reboot'
    # D: shut down
    bindsym Shift+d          mode "default"; exec swaynag -t warning \
                                 -m 'Do you really want to shut down the system?' \
                                 -b 'Shutdown' 'systemctl poweroff'

    ## p: switch audio profile off/on (same pactl commands work via PipeWire compat)
    #bindsym p                mode "default"; \
    #                             exec pactl set-card-profile 0 off; \
    #                             exec sh -c 'sleep 1; pactl set-card-profile 0 output:hdmi-stereo-extra1'
    ## P: restart PipeWire/WirePlumber (replaces pkill pulseaudio)
    #bindsym Shift+p          mode "default"; exec systemctl --user restart wireplumber

    bindsym Return           mode "default"
    bindsym Escape           mode "default"
}

# AltGr+Scroll_Lock: pointer mode
set $mode_pointer Pointer: [p]rofile (adaptive↔flat)  accel [1]=1.0 [2]=0.9 [3]=0.8 [4]=0.7 [5]=0.6 [6]=0.5 [7]=0.4 [8]=0.3 [9]=0.2 [0]=0.0
bindsym $altgr+Scroll_Lock mode "$mode_pointer"; exec sway-mode-timeout $mode_timeout_secs
mode "$mode_pointer" {
    # p: toggle between adaptive (desktop) and flat (gaming) profile
    bindsym p      exec sway-mouse-accel toggle-profile, mode "default"
    # 0-9: set pointer_accel value and exit mode
    bindsym 0      exec sway-mouse-accel 0, mode "default"
    bindsym 1      exec sway-mouse-accel 1, mode "default"
    bindsym 2      exec sway-mouse-accel 2, mode "default"
    bindsym 3      exec sway-mouse-accel 3, mode "default"
    bindsym 4      exec sway-mouse-accel 4, mode "default"
    bindsym 5      exec sway-mouse-accel 5, mode "default"
    bindsym 6      exec sway-mouse-accel 6, mode "default"
    bindsym 7      exec sway-mouse-accel 7, mode "default"
    bindsym 8      exec sway-mouse-accel 8, mode "default"
    bindsym 9      exec sway-mouse-accel 9, mode "default"
    bindsym Return mode "default"
    bindsym Escape mode "default"
}
