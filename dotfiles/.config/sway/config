# {{{ = Window Rules =========================================================
# {{{ - Default Workspaces ---------------------------------------------------
# SWAY: [class=...] matches XWayland apps; [app_id=...] matches Wayland-native apps.
#       Both are kept here for broad compatibility.

# WS 2 - Web
for_window [class="(?i)(.*chrome|firefox)"]         move container to workspace $ws2
for_window [app_id="firefox"]                        move container to workspace $ws2
for_window [app_id="(?i)(google-chrome|chromium)"]  move container to workspace $ws2

# WS 3 - Dev
for_window [class="(?i)code$"]                    move container to workspace $ws3
for_window [app_id="code"]                        move container to workspace $ws3
for_window [app_id="com.visualstudio.code"]       move container to workspace $ws3  # Flatpak VSCode

# WS 4 - Media
for_window [class="TeamViewer"]  move container to workspace $ws4

# WS 5 - Misc
for_window [class="(?i)XnView(MP)?"] move container to workspace $ws5

# WS 9 - Tray
for_window [class="spotify"]         move container to workspace $ws9
for_window [app_id="spotify"]        move container to workspace $ws9
for_window [title="JDownloader"]     move container to workspace $ws9

# WS 10 - Music
for_window [class="pavucontrol"]  move container to workspace $ws10
for_window [app_id="pavucontrol"] move container to workspace $ws10

# KeePassXC: floating + sticky so unlock/auth prompts are visible on any workspace.
# Flatpak app_id is "org.keepassxc.KeePassXC" (starts with "org."), so use .*keepassxc.*
# to match both native and flatpak. Sway anchors regex, so keepassxc.* alone won't match.
for_window [app_id="(?i).*keepassxc.*"] floating enable, sticky enable
for_window [class="(?i)keepassxc.*"]    floating enable, sticky enable
for_window [class="nextcloud"]  move to workspace $ws10
for_window [app_id="nextcloud"] move to workspace $ws10
# }}} - Default Workspaces ---------------------------------------------------

# {{{ - Window Modes ---------------------------------------------------------
# float by role (XWayland apps only — Wayland apps use app_id)
for_window [window_role="i3float"]  $FLOAT

# SWAY: app_id="swayfloat" is used for Wayland terminal windows that should float
#       (replaces i3-sensible-terminal -r i3float pattern)
for_window [app_id="swayfloat"]     $FLOAT

# float by class / title / app_id
for_window [class="^(?i)(mpv|galculator)$"]    $FLOAT
for_window [app_id="^(?i)(mpv|galculator)$"]   $FLOAT
for_window [title="^Task Manager - Google Chrome$"] $FLOAT

# full screen by class
for_window [class="streaming_client"] fullscreen enable
# }}} - Window Modes ---------------------------------------------------------
# }}} = Window Rules =========================================================

# {{{ = Launch Apps ==========================================================
# Propagate key env vars to systemd user session and D-Bus.
# Required so xdg-desktop-portal, pipewire, and other socket-activated services
# inherit WAYLAND_DISPLAY and XDG_CURRENT_DESKTOP (set in sway-nvidia).
exec --no-startup-id dbus-update-activation-environment --systemd \
    WAYLAND_DISPLAY XDG_CURRENT_DESKTOP DISPLAY

# xdg-desktop-portal backend is configured via ~/.config/xdg-desktop-portal/portals.conf.
# No manual restart needed — the portal starts via socket activation and reads portals.conf.

# Idle management and screen locking (swayidle + swaylock)
# Install: sudo apt install swayidle swaylock
# -w: wait for lock command to finish before sleeping (critical for before-sleep)
# PAM auth (incl. U2F): sudo install -m 644 /dev/null /etc/pam.d/swaylock
#   echo 'auth include common-auth' | sudo tee /etc/pam.d/swaylock
exec --no-startup-id swayidle -w \
    timeout 300  'swaylock -f -c 000000' \
    timeout 600  'swaymsg "output * dpms off"' \
    resume       'swaymsg "output * dpms on"' \
    before-sleep 'swaylock -f -c 000000'

# Notification daemon (mako — lightweight Wayland-native)
# Install: sudo apt install mako-notifier
# https://github.com/emersion/mako
# Configurable: `man 5 mako` - https://github.com/emersion/mako/blob/master/doc/mako.5.scd
# Control: `man makoctl` - https://github.com/emersion/mako/blob/master/doc/makoctl.1.scd
exec --no-startup-id mako

# {{{ - Launch Apps after waybar ---------------------------------------------
# KeePassXC (flatpak, auto-updates to latest stable).
# The XDG autostart entry (~/.config/autostart/keepassxc.desktop) points to an
# outdated AppImage path and is skipped by systemd, so we launch it explicitly here.
# Wait until waybar is running, then add 2s for the tray module to initialize,
# before starting KeePassXC so it can register its tray icon.
exec --no-startup-id sh -c 'until pgrep -x waybar > /dev/null; do sleep 1; done; sleep 2; flatpak run org.keepassxc.KeePassXC'

# Network Manager applet — tray icon for network/VPN status.
# Also started via systemd XDG autostart (app-nm-applet@autostart.service);
# nm-applet deduplicates itself via D-Bus so only one instance runs.
exec --no-startup-id nm-applet --indicator

# conky system monitor (runs via XWayland)
#exec --no-startup-id conky -p 3 -o -c ~/.conky/conkyrc-syslog
#exec --no-startup-id conky -p 3 -o -c ~/.conky/conkyrc-sysmon2

# nextcloud client (1min delay so KeePassXC can unlock first)
#exec --no-startup-id sh -c 'sleep 60; nextcloud'
exec --no-startup-id sh -c 'until pgrep -x waybar > /dev/null; do sleep 1; done; sleep 2; nextcloud'

# NordVPN client UI
exec --no-startup-id sh -c 'until pgrep -x waybar > /dev/null; do sleep 1; done; sleep 2; nordvpn-ui'
# }}} - Launch Apps after waybar ---------------------------------------------
# }}} = Launch Apps ==========================================================
