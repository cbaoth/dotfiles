# {{{ - Run Apps: Hyper Key --------------------------------------------------
# Run-or-raise convention: $hyper+{key} focuses an existing window if one
# exists (else launches), via bin/sway-app. $hyper+Shift+{key} bypasses this
# and always launches a new instance -- only bound for apps where running
# more than one instance is actually useful (e.g. file managers).

# hyper-e: double-commander file manager (focus existing, else launch)
bindsym $hyper+e             exec sway-app doublecmd
# hyper-Shift-e: double-commander, always start a new instance
bindsym $hyper+Shift+e       exec doublecmd

# hyper-Ctrl-e: nautilus file manager (focus existing, else launch)
bindsym $hyper+Ctrl+e        exec sway-app nautilus
# hyper-Ctrl-Shift-e: nautilus, always start a new instance
bindsym $hyper+Ctrl+Shift+e  exec nautilus

# hyper-o: Obsidian, toggle visibility -- focus if hidden/elsewhere, hide to
# scratchpad if already visible, launch if not running. Deterministic
# show/hide for this one app, unlike the FIFO-queue-based scratchpad bindings.
bindsym $hyper+o             exec sway-app -m obsidian -A toggle -- flatpak run md.obsidian.Obsidian
