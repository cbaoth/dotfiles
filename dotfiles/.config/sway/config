# Full screen
for_window [class="(?i)^streaming.?client$"]               fullscreen enable

# Idle inhibit: keep the screen awake while any window is fullscreen (games /
# fullscreen video that does not set its own inhibitor). `inhibit_idle
# fullscreen` only inhibits while the window is actually fullscreen; it
# registers as an application inhibitor. [class=".*"] matches XWayland windows,
# [app_id=".*"] Wayland windows — together, all windows.
for_window [app_id=".*"]                                   inhibit_idle fullscreen
for_window [class=".*"]                                    inhibit_idle fullscreen

# sway-awake (bin/sway-awake): invisible holder window for the *manual* keep-awake
# toggle. Spawned/killed on demand; `inhibit_idle open` holds a *user* idle
# inhibitor for as long as the window exists, distinguishing manual mode from
# application inhibitors (media/games) in `swaymsg -t get_tree`.
# MUST come after the catch-all above so `open` wins over `fullscreen`.
# foot enforces a minimum window size (~72x39), so we cannot shrink it to 1x1;
# instead park it fully off-screen (negative coords) and set opacity 0 so it is
# invisible and cannot catch pointer clicks. inhibit_idle holds while it exists.
no_focus   [app_id="^sway-awake-idle-inhibitor$"]
for_window [app_id="^sway-awake-idle-inhibitor$"] \
    floating enable, border none, opacity 0, \
    move position -500 -500, inhibit_idle open
