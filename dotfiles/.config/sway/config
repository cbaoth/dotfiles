# waybar is the recommended bar for Sway - Wayland-native, supports tray icons
# (KeePassXC, NordVPN, nm-applet, etc.), configurable via ~/.config/waybar/
# Install: sudo apt install waybar
# Config:  see https://github.com/Alexays/Waybar/wiki/Configuration
bar {
    swaybar_command waybar

    # Source: https://github.com/rkubosz/base16-sway/blob/master/config
    colors {
        background $base00
        separator  $base01
        statusline $base04

        #                   Border  BG      Text
        focused_workspace   $base05 $base0D $base00
        active_workspace    $base05 $base03 $base00
        inactive_workspace  $base03 $base01 $base05
        urgent_workspace    $base08 $base08 $base00
        binding_mode        $base00 $base0A $base00
    }
}

