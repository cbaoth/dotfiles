# {{{ = Variables ============================================================
# default mod key (Super_L/Super_R keys, usually the Windows key)
set $mod Mod4

# alternative mod key (Hyper_L, ISO key between Left Shift and Z on ISO keyboards)
# Requires ~/.config/xkb/symbols/custom to map <LSGT> to Hyper_L on Mod3, e.g.:
# ----
# xkb_symbols "basic" {
#   include "us(colemak)"
#   name[Group1] = "English (Colemak + ISO mod)";
#   key <LSGT> { [ Hyper_L, Hyper_L ] };
#   modifier_map Mod3 { Hyper_L };
# }
# ----
# https://wiki.archlinux.org/title/Sway#Change_modifier_to_CapsLock_and_keep_Super
set $hyper Mod3

# default $mod+x chord mapping mod keys, e.g. via /etc/keyd/default.conf:
# ----
# [meta_chord]
# a = M-C-A-S-a
# b = M-C-A-S-b
# c = M-C-A-S-c
# ...
# [meta]
# x = timeout(oneshot(meta_chord), 1000, M-x)
# ----
# FIXE dosen't work this way
#set $cmods Mod4+Ctrl+Mod1+Shift

# SWAY: preferred Wayland-native terminal (foot is lightweight and native)
# Alternatives: alacritty, kitty, wezterm, gnome-terminal
set $term foot

# workspace numbers and names
set $ws1  "1:Main"
set $ws2  "2:Web"
set $ws3  "3:Dev"
set $ws4  "4:Media"
set $ws5  "5:Misc"
set $ws6  "6:Misc"
set $ws7  "7:Misc"
set $ws8  "8:Misc"
set $ws9  "9:Tray"
set $ws10 "10:Music"

# (un-)floating command, floating borderless
set $FLOAT floating enable, border normal 0
set $UNFLOAT floating disable, border normal 2
# }}} = Variables ============================================================

# {{{ = Key Bindings =========================================================
# {{{ - Window/Container Navigation ------------------------------------------
# alt-F4: close/kill focused window
bindsym Mod1+F4 kill

# SWAY: floating_modifier requires 'normal' or 'inverse' as second argument
# Mouse+$mod: drag floating windows
floating_modifier $mod normal

# mod-(Shift-)tab/grave: change focus (left/right/up/down)
bindsym $mod+Shift+Tab   focus left
bindsym $mod+Tab         focus right
bindsym $mod+Shift+grave focus up
bindsym $mod+grave       focus down

# mod-left/right/up/down: same as above (alt. keys)
bindsym $mod+Left  focus left
bindsym $mod+Right focus right
bindsym $mod+Up    focus up
bindsym $mod+Down  focus down

# mod+Shift-left/right/up/down: move focused window
bindsym $mod+Shift+q  move left
bindsym $mod+Shift+w move right
bindsym $mod+Shift+f    move up
bindsym $mod+Shift+p  move down

# mod+Shift-left/right/up/down: move focused window (alt. keys)
bindsym $mod+Shift+Left  move left
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Up    move up
bindsym $mod+Shift+Down  move down

# split in horizontal orientation
bindsym $mod+h layout splith
bindsym $mod+Shift+h split h

# split in vertical orientation
bindsym $mod+v layout splitv
bindsym $mod+Shift+v split v

# enter fullscreen mode for the focused container
bindsym $mod+Alt+z fullscreen toggle

# toggle sticky state (visible on current / all workspaces)
bindsym $mod+Alt+s sticky toggle

# mod-q/w/W: change container layout (toggle-split/tabbed/stacked)
bindsym $mod+s layout toggle split
bindsym $mod+Shift+s layout stacking
bindsym $mod+t layout tabbed
# mod-f/mod-F: float/un-float
bindsym $mod+d $FLOAT
bindsym $mod+Shift+d $UNFLOAT
# mod-p: focus between tiling / floating windows
bindsym $mod+p focus mode_toggle
# mod-P: switch border style
bindsym $mod+Shift+b border toggle

# mod-a/A: focus parent/child container
bindsym $mod+a focus parent
bindsym $mod+Shift+a focus child
# }}} - Window/Container Navigation ------------------------------------------

# {{{ - Workspace Navigation -------------------------------------------------
# mod-z/Z: move current to / retrieve first window from scratchpad
bindsym $mod+z move scratchpad
bindsym $mod+Shift+z scratchpad show
#bindsym $mod+slash [title="Visual Studio Code$"] scratchpad show

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# switch workspace previous/next
bindsym $mod+Ctrl+Right workspace next
bindsym $mod+Ctrl+Left  workspace prev

# move focused container to workspace (and disable sticky mode)
bindsym $mod+Shift+1 sticky disable; move container to workspace $ws1
bindsym $mod+Shift+2 sticky disable; move container to workspace $ws2
bindsym $mod+Shift+3 sticky disable; move container to workspace $ws3
bindsym $mod+Shift+4 sticky disable; move container to workspace $ws4
bindsym $mod+Shift+5 sticky disable; move container to workspace $ws5
bindsym $mod+Shift+6 sticky disable; move container to workspace $ws6
bindsym $mod+Shift+7 sticky disable; move container to workspace $ws7
bindsym $mod+Shift+8 sticky disable; move container to workspace $ws8
bindsym $mod+Shift+9 sticky disable; move container to workspace $ws9
bindsym $mod+Shift+0 sticky disable; move container to workspace $ws10

# mod-b: toggle bar mode (dock↔hide)
bindsym $mod+b bar mode toggle
# SWAY: bar hidden_state does not exist in Sway; bar mode toggle covers both
# bindsym $mod+Shift+b bar hidden_state toggle
# }}} - Workspace Navigation -------------------------------------------------

# {{{ - Meta Modes -----------------------------------------------------------
# mod-x: meta mode
set $mode_meta Meta: (c)lose window
bindsym $mod+x mode "$mode_meta"
mode "$mode_meta" {
    bindsym c kill, mode "default"
    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# mod-g: resize window mode
set $mode_resize Resize: n/e/i/o or arrow keys
bindsym $mod+g mode "$mode_resize"
mode "$mode_resize" {
    bindsym n resize shrink width  10 px or 10 ppt
    bindsym e resize grow   height 10 px or 10 ppt
    bindsym i resize shrink height 10 px or 10 ppt
    bindsym o resize grow   width  10 px or 10 ppt

    bindsym Left  resize shrink width  10 px or 10 ppt
    bindsym Down  resize grow   height 10 px or 10 ppt
    bindsym Up    resize shrink height 10 px or 10 ppt
    bindsym Right resize grow   width  10 px or 10 ppt

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

# mod-BackSpace: system mode
# SWAY: i3-nagbar → swaynag, i3-msg → swaymsg, dm-tool lock → swaylock
#       xsuspend → swaylock -f && systemctl suspend
#       restart  → reload  (sway has no in-place restart equivalent)
set $mode_system Sway: (l)ock, re-(c)onfigure/reload, (e)xit -- System: (S)uspend, (H)ibernate, re(B)oot, Shut(D)own, restart (P)ipeWire
bindsym $mod+BackSpace mode "$mode_system"
mode "$mode_system" {
    # l: lock screen
    bindsym l exec swaylock -c 000000, mode "default"
    # c: reload the configuration file (sway has no restart, reload is equivalent)
    bindsym c reload, mode "default"
    # e: exit sway
    bindsym e exec swaynag -t warning -m 'Do you really want to exit Sway?' \
        -b 'Exit Sway' 'swaymsg exit'

    # S: lock screen + suspend
    bindsym Shift+s mode "default"; exec swaylock -f -c 000000 && systemctl suspend
    # H: lock screen + hibernate
    bindsym Shift+h mode "default"; exec swaylock -f -c 000000 && systemctl hibernate
    # B: reboot
    bindsym Shift+b exec swaynag -t warning \
        -m 'Do you really want to reboot the system?' \
        -b 'Reboot' 'systemctl reboot'
    # D: shut down
    bindsym Shift+d exec swaynag -t warning \
        -m 'Do you really want to shut down the system?' \
        -b 'Shutdown' 'systemctl poweroff'

    # P: restart PipeWire/WirePlumber (replaces pkill pulseaudio)
    bindsym Shift+p mode "default"; exec systemctl --user restart wireplumber
    # p: switch audio profile off/on (same pactl commands work via PipeWire compat)
    bindsym p mode "default"; \
        exec pactl set-card-profile 0 off; \
        exec sh -c 'sleep 1; pactl set-card-profile 0 output:hdmi-stereo-extra1'

    bindsym Return mode "default"
    bindsym Escape mode "default"
}
# }}} - Meta Modes -----------------------------------------------------------

# {{{ - Special Keys ---------------------------------------------------------
# volume media keys
bindsym XF86AudioRaiseVolume exec --no-startup-id media-keys -o vol+
bindsym XF86AudioLowerVolume exec --no-startup-id media-keys -o vol-
bindsym XF86AudioMute        exec --no-startup-id media-keys -o mute

# mod4-mod1-=/-/0: alt. volume keys
bindsym Mod4+Mod1+equal exec --no-startup-id media-keys -o vol+
bindsym Mod4+Mod1+minus exec --no-startup-id media-keys -o vol-
bindsym Mod4+Mod1+0     exec --no-startup-id media-keys -o mute

# media player keys (req.: playerctl)
bindsym XF86AudioPlay exec --no-startup-id media-keys -o play-pause
bindsym XF86AudioPrev exec --no-startup-id media-keys -o previous
bindsym XF86AudioNext exec --no-startup-id media-keys -o next

# mod4-mod1-Space/,/.: alt. media player keys
bindsym Mod4+Mod1+space  exec --no-startup-id media-keys -o play-pause
bindsym Mod4+Mod1+comma  exec --no-startup-id media-keys -o previous
bindsym Mod4+Mod1+period exec --no-startup-id media-keys -o next

# SWAY: xbacklight → brightnessctl (works natively on Wayland)
bindsym XF86MonBrightnessUp   exec brightnessctl set +20%
bindsym XF86MonBrightnessDown exec brightnessctl set 20%-

# home button: start browser
bindsym XF86HomePage exec firefox

# print button: screenshot
# SWAY: flameshot works on Wayland; grimshot (sway-contrib) is a native alternative:
#   exec grimshot copy area
bindsym Print exec --no-startup-id flameshot gui

# mod-l: lock screen (mirrors Windows/GNOME Mod4+L)
bindsym $mod+l exec swaylock -f -c 000000
# }}} - Special Keys ---------------------------------------------------------

# {{{ - Run Apps -------------------------------------------------------------
# mod-return: run terminal
# SWAY: i3-sensible-terminal → $term (set to 'foot' above)
bindsym $mod+Return exec $term

# mod-space: rofi run launcher (consistent with GNOME setup)
# Under Sway/Wayland, rofi works natively — no -normal-window needed
bindsym $mod+space exec rofi -show combi

# chord-mods-d (mod-x, d): double-commander file manager
#$cmods+d exec doublecmd
#$hyper+d exec doublecmd
# chord-mods-n (mod-x, n): nautilus file manager
#$cmods+n exec nautilus

# mod-ESC: run htop in floating terminal
# SWAY: -r i3float (WM_WINDOW_ROLE) not supported for Wayland apps;
#       use --app-id instead, matched by for_window rule below
bindsym $mod+Escape exec $term --app-id=swayfloat -e htop

# mod-F1: open ssh session
# Note: gnome-keyring-daemon may not start cleanly outside GNOME;
#       consider using KeePassXC as SSH agent instead (Settings → SSH Agent)
bindsym $mod+F1 exec $term -e ssh -p 8090 -A 11001001.org
