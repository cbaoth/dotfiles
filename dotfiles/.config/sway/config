# {{{ = Output / Input =======================================================
# Configure your outputs (monitors) here.
# Run: swaymsg -t get_outputs   (to list available outputs)

# LG Electronics 38GN950 (3840x1600 ultrawide) on DP-1
# Detected from log: LG Electronics 38GN950 205NTMX6L403
output DP-1 resolution 3840x1600 position 0,0
# output DP-1 scale 1.25  # optional HiDPI scaling

# Desktop background (replaces xsetroot / feh)
# SWAY: sway handles wallpaper natively via output
output * bg #000000 solid_color
#output * bg ~/.wallpaper.jpg fill

# {{{ - Input ----------------------------------------------------------------
# Run: swaymsg -t get_inputs   (to list input identifiers)

input "type:keyboard" {
    # Custom XKB layout: us(colemak) + ISO key (<LSGT>) mapped to Hyper_L on Mod3.
    # CapsLock → Backspace is built into us(colemak).
    # AltGr layer provides umlauts: AltGr+q=ä  AltGr+s=ß  AltGr+a=á  etc.
    # Symbols file: ~/.config/xkb/symbols/custom (dotfiles symlink)
    # libxkbcommon searches ~/.config/xkb/ before system paths automatically.
    xkb_layout  custom
    xkb_variant basic

    # xkb_options lv3:ralt_switch  # uncomment if AltGr stops working

    # Key repeat (mirrors xsession: xset r 66)
    # CapsLock/Backspace repeats because repeat applies to all keys
    repeat_delay 300
    repeat_rate  30
}

#input "type:touchpad" {
#    tap               enabled
#    natural_scroll    enabled
#    scroll_factor     0.5
#}
# }}} - Input ----------------------------------------------------------------
# }}} = Output / Input =======================================================

