# ~/.gitconfig — universal git configuration, tracked in cbaoth/dotfiles.
#
# Machine-specific settings (credential helper, work identity, OS quirks) do
# NOT belong here — this repo is public. They live in the untracked
# ~/.gitconfig.local; see .gitconfig.local.example for the template.

[user]
	name = Andreas Weyer
	email = dev@cbaoth.de

[init]
	defaultBranch = main

[pull]
	# Rebase local commits onto fetched ones instead of a merge commit. Set
	# globally so every repo behaves the same, with no per-clone step (and no
	# "you have divergent branches" hint after the fact).
	rebase = true

[rebase]
	# Auto-stash a dirty working tree before a rebase (incl. `pull --rebase`)
	# and re-apply it after — no more "cannot rebase: you have unstaged
	# changes". The stash is restored even if the rebase is aborted.
	autoStash = true

[merge]
	# 3-way conflict markers: also show the original (merge-base) text between
	# ||||||| and =======, not just ours vs theirs. Makes "both sides changed
	# this" conflicts actually resolvable instead of a guessing game.
	conflictStyle = zdiff3

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

# Loaded last, so machine-local settings win over the defaults above. A missing
# file is silently ignored, so this is safe on a host that has no local config.
[include]
	path = ~/.gitconfig.local
