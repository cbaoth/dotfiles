# http://wiki.hydrogenaudio.org/index.php?title=Foobar2000:ID3_Tag_Mapping
alias id3-clean-rec='find -type f -iname "*.mp3" -exec eyeD3 \
  --remove-comments --set-text-frame="TENC:" --set-text-frame="TOWN:" \
