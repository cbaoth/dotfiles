ffmpeg-clip-extract() {
  [[ $# -ne 3 ]] && echo "Usage: ffmpeg-clip-extract infile start_time duration" && return 1
  local infile="$1"
  local start_time="$2"
  local duration="$3"
  local outfile="${infile%.*}_${start_time//:/.}_${duration//:/.}.${infile##*.}"
  ffmpeg -i "${infile}" -ss "${start_time}" -t "${duration}" -c copy "${outfile}"
}
