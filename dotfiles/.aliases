alias tr-to-lowercase="tr '[A-Z]' '[a-z]'"
alias tr-to-uppercase="tr '[a-z]' '[A-Z]'"

# shellcheck disable=SC2142  # \$1 is escaped, passed as literal $1 to rename's regex
alias rename-reduce-periods-to-underscore="rename 's/\./_/g;s/_([^_]{1,5})$/.\$1/'"
# shellcheck disable=SC2142  # \$1 is escaped, passed as literal $1 to rename's regex
alias rename-reduce-spaces-to-underscore="rename 's/ /_/g;s/_([^_]{1,5})$/.\$1/'"

alias rename-strip-specials="rename \"s/[^ \w()\[\]~&%#@.,+'-]/_/g\""
alias rename-strip-specials-rec="find . -depth -type f -execdir rename \"s/^\.\///g;
  s/[^ \w()\[\]~&%#@.,+'-]/_/g; s/^/\.\//\" '{}' +"

# TODO review these rename aliases; they may not even work correctly (a very limited approach)
# shellcheck disable=SC2139,SC2142  # \$1/\$2 prevent shell expansion; $1/$2 are Perl backrefs inside single quotes
alias rename-to-titlecase="rename 's/(^|[\s_-])([a-z])/\$1\u\$2/g'"
# shellcheck disable=SC2139,SC2142  # \$2 prevents shell expansion; $2 is a Perl backref inside single quotes
alias rename-to-camelcase="rename 's/(^|[\s_-])([a-z])/\u\$2/g'"

rename-add-date-prefix() {
  local mode=skip  # skip (default)|replace|force
  while (( $# > 0 )); do
    case "$1" in
      --replace) mode=replace; shift ;;
      --force)   mode=force;   shift ;;
      --)        shift; break ;;
      -*)        printf '\033[31mERROR\033[0m: Unknown option: %s\n' "$1" >&2; return 1 ;;
      *)         break ;;
    esac
  done
  if (( $# < 2 )); then
    printf '\033[31mERROR\033[0m: Usage: rename-add-date-prefix [--replace|--force] <mtime|ctime|exif> FILE...\n' >&2
    return 1
  fi
  local ts_type="$1"; shift
  local stat_flag
  case "${ts_type}" in
    mtime) stat_flag='%Y' ;;
    ctime) stat_flag='%Z' ;;
    exif)  ;;
    *) printf '\033[31mERROR\033[0m: Unknown type: %s (use mtime, ctime, or exif)\n' "${ts_type}" >&2; return 1 ;;
  esac
  local f dir base ts_epoch prefix
  for f in "$@"; do
    dir=$(dirname "${f}")
    base=$(basename "${f}")
    if [[ "${base}" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{6}_ ]]; then
      case "${mode}" in
        skip)    printf '\033[33mWARNING\033[0m: Skipping (already prefixed): %s\n' "${f}" >&2; continue ;;
        replace) base="${base:18}" ;;  # strip fixed 18-char prefix YYYY-MM-DDTHHMMSS_
        force)   ;;
      esac
    fi
    if [[ "${ts_type}" == exif ]]; then
      prefix=$(exiftool -s3 -d "%Y-%m-%dT%H%M%S_" -DateTimeOriginal "${f}")
      if [[ -z "${prefix}" ]]; then
        printf '\033[33mWARNING\033[0m: Skipping (no EXIF DateTimeOriginal): %s\n' "${f}" >&2
        continue
      fi
    else
      ts_epoch=$(stat -c "${stat_flag}" "${f}")
      prefix=$(date -d "@${ts_epoch}" +%Y-%m-%dT%H%M%S_)
    fi
    mv -v "${f}" "${dir}/${prefix}${base}"
  done
}

alias sed-to-titlecase="sed -E 's/(^|[\s_-])([a-z])/\1\u\2/g'"
alias sed-to-camelcase="sed -E 's/(^|[\s_-])([a-z])/\u\2/g'"

alias sed-url-clean="sed 's/%3a/:/gi; s/%2f/\//gi; s/[?&].*//g; s/%26/&/gi;
                          s/%3d/:/gi; s/%3f/?/gi'"
alias sed-url-clean2="sed 's/%3a/:/gi; s/%2f/\//gi; s/%26/&/gi; s/%3d/:/gi;
                           s/%3f/?/gi'"

# TODO review this alias, it seems to be incorrect/broken (even before the shellcheck related change)
# shellcheck disable=SC2154  # l is assigned by while read l; shellcheck confused by alias body
alias sed-url-decode="sed -E 's/%([0-9A-F][0-9A-F])/\\\\x\1/g' | while read l; do echo -e \"\$l\"; done"

alias cat-utf16-to-utf8='iconv -f utf-16 -t utf-8'
alias cat-utf16-to-iso-8859-1='iconv -f utf-16 -t ISO-8859-1'
alias cat-utf8-to-iso-8859-1='iconv -f utf-8 -t ISO-8859-1'
# }}} - SUBSTITUTION ---------------------------------------------------------

# {{{ - MISC -----------------------------------------------------------------
alias cal-month='ncal -wM -m'
alias cal-year='ncal -ywM'

alias dupes-rm='jdupes -dNO -o time'
alias dupes-rm-rec='jdupes -dNOr -o time'

alias dupes-find='jdupes -O -o time'
alias dupes-find-rec='jdupes -Or -o time'

alias dupes-find-unique='jdupes -O -u'
alias dupes-find-unique-rec='jdupes -Or -u'
# NOTE: also see dupes_find_byname and dupes_mv in lib/functions.sh

alias mysqlr='mysql -u root -p'
alias postgres-list="sudo -u postgres psql -c '\l'"
alias nice-java='ionice -n 19 `pgrep java`; renice -n 19 -p `pgrep java`'
alias sleep-usb='sudo ~/bin/scsi-idle 900&'
rpm-extract() { rpm2cpio "$1" | cpio -ivd; }

alias occ='sudo -u www-data php --define apc.enable_cli=1 /var/www/nextcloud/occ'
alias occd='cd /var/www/nextcloud; sudo -u www-data php --define apc.enable_cli=1 occ'

alias wallabag-console='sudo -u www-data php /var/www/wallabag.11001001.org/bin/console -e prod'
# }}} - MISC -----------------------------------------------------------------

# {{{ - DOTFILES MANAGEMENT --------------------------------------------------
# Run dotfiles link.sh and refresh shell command cache.
# Shell-agnostic: resolves repo root by following .aliases symlink.
# shellcheck disable=SC2120  # arguments optional, function for cli use only
dotfiles-link() {
  local _aliases_path _df_root

  # Resolve repo root by following the .aliases symlink
  # (.aliases is at dotfiles/dotfiles/.aliases, so go up 2 levels)
  if _aliases_path=$(readlink -f "${HOME}/.aliases" 2>/dev/null); then
    _df_root="$(dirname "$(dirname "${_aliases_path}")")"
  else
    # Fallback if readlink fails (e.g., not symlinked yet)
    _df_root="${HOME}/dotfiles"
  fi

  # Run linking and refresh command cache (works in both bash and zsh)
  "${_df_root}/tools/link.sh" "$@" && {
    hash -r 2>/dev/null || rehash 2>/dev/null
  }
}

# Pull latest dotfiles from remote repository and apply linking.
# Shell-agnostic: uses same path resolution as dotfiles-link.
dotfiles-update() {
  local _aliases_path _df_root

  if _aliases_path=$(readlink -f "${HOME}/.aliases" 2>/dev/null); then
    _df_root="$(dirname "$(dirname "${_aliases_path}")")"
  else
    _df_root="${HOME}/dotfiles"
  fi

  git -C "${_df_root}" pull "$@" && dotfiles-link
}
# }}} - DOTFILES MANAGEMENT --------------------------------------------------

# {{{ - SHELL NAVIGATION -----------------------------------------------------
# alias /='cd /' is zsh-only (invalid alias name in bash) — defined in aliases.zsh
alias h='history'
alias hs='history | grep -Ei'
# }}} - SHELL NAVIGATION -----------------------------------------------------

# {{{ - PYTHON / CONDA -------------------------------------------------------
# https://docs.conda.io/projects/conda/en/latest/commands/index.html
if ${HAS_CONDA:-false}; then
  # conda environments
  alias condai="conda init"
  alias condar="conda run"
  alias condaa="conda activate"
  alias condad="conda deactivate"
  alias condac="conda check"
  alias condal="conda list"
  # conda packages
  alias condaps="conda search"
  alias condapi="conda install"
  alias condapr="conda remove"
  alias condapu="conda update"
  alias condapua="echo 'NOTE: Running conda update --all might not update all the packages in a given environment to their latest versions. If the latest version of a package is incompatible with other packages installed in the environment, conda will only update that package to the latest compatible version.' >&2; conda update --all"
  alias condapc="conda clean"
  alias condapd="conda compare"
  alias 'conda?'="conda info"
  # conda base
  alias conda-update-base="conda update -n base -c defaults conda"
fi
# }}} - PYTHON / CONDA -------------------------------------------------------

# {{{ - PYTHON / UV -----------------------------------------------------------
# https://docs.astral.sh/uv/getting-started/features/
if command -v uv >/dev/null 2>&1; then
  # project env (./.venv)
  alias uvs="uv sync --all-extras"
  alias uvr="uv run"
  alias uva="uv add"
  alias uvad="uv add --dev"
  alias uvrm="uv remove"
  alias uvl="uv lock"
  # common dev tooling via the project .venv
  alias uvt="uv run pytest"
  alias uvfmt="uv run ruff format ."
  alias uvc="uv run ruff check ."
  alias uvcf="uv run ruff check . --fix"
  alias uvpr="uv run pyright"
  # global tool installs (~/.local/bin), independent of any project .venv
  alias uvti="uv tool install --editable ."
  alias uvtu="uv tool upgrade"
  alias uvtl="uv tool list"
  alias uvtun="uv tool uninstall"
  # python version management
  alias uvpi="uv python install"
  alias uvpl="uv python list"
fi
# }}} - PYTHON / UV -----------------------------------------------------------

# shellcheck disable=SC1091  # optional local override; path is dynamic
[[ -f "$HOME/.aliases.local" ]] && source "$HOME/.aliases.local"

return 0
