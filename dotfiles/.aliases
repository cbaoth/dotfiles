# -*- mode: sh; sh-shell: bash; indent-tabs-mode: nil; tab-width: 2 -*-
# vim: ft=bash:et:ts=2:sts=2:sw=2
# code: language=bash insertSpaces=true tabSize=2
# shellcheck shell=bash disable=SC2148
#
# ~/.aliases: Common aliases.

# Common aliases for all shells

# {{{ - GENERAL --------------------------------------------------------------
# allow sudo and other commands to use aliases as arguments
# https://askubuntu.com/a/22043/234212
alias sudo='sudo '
alias watch='watch '

# change directory shortcuts
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# file operations
alias cp='cp -i'
alias mv='mv -i'

# find with regex (POSIX extended) by default
findre () {
  local paths=()
  local expressions=()
  local in_paths=true

  # Consume leading non-expression args as paths; once an expression token is seen
  # (starts with '-', or is '!', '(', ')'), everything remaining is an expression.
  # This matches find's grammar: paths always precede predicates, and predicate
  # arguments (e.g. 'd' in '-type d') must not be misclassified as paths.
  for arg in "$@"; do
    if "${in_paths}" && [[ "$arg" != -* && "$arg" != "!" && "$arg" != "(" && "$arg" != ")" ]]; then
      paths+=("$arg")
    else
      in_paths=false
      expressions+=("$arg")
    fi
  done

  # If no path was provided, find defaults to the current directory '.'
  if (( ${#paths[@]} == 0 )); then
    paths=(".")
  fi

  # Execute with -regextype safely injected exactly between paths and expressions since order matters.
  # `-regextype posix-extended` must come before the expressions, else `findutils-default` is used
  command find "${paths[@]}" -regextype posix-extended "${expressions[@]}"
}

# add --color option to all grep commands and add -i aliases
# shellcheck disable=SC2139  # ${c} intentionally expands at definition time to build alias names/values
for c in '' e f r z; do
  alias ${c}grep="${c}grep --color"
  alias ${c}grepi="${c}grep --color -i"
done

#alias sws='echo 4 > /proc/acpi/sleep'
alias psa='ps uxaw --cols 64000'
alias psag='ps uxaw --cols 64000 | grep -iE'
alias psf='ps aw --forest --cols 64000'
alias psfg='ps aw --forest --cols 64000 | grep -iE'

# find/kill processes by pattern (case-insensitive ERE, matched against the
# full command line). `pf` lists PID + full cmdline to verify before killing;
# `pk`/`pk9` send SIGTERM/SIGKILL to the same matches (no pgrep|xargs needed).
alias pf='pgrep -aif'         # e.g. pf 'java.*some-app.jar'
alias pk='pkill -if'          # SIGTERM
alias pk!='pkill -9 -if'      # SIGKILL (case-insensitive, ERE, full command line match)
alias pk!x='pkill -9 -x'      # SIGKILL (exact match)
alias killall9='pk!x'         # legacy name, for convenience (similar to similar to `killall -9`)

alias kill-suspend='kill -TSTP'
alias kill-resume='kill -CONT'

# dmesg piped to less with timestamp format and colors
alias dmesgp='sudo dmesg -wT --color=always | less -R'
alias dmesgj='journalctl -ko short-monotonic --no-hostname --no-pager'
alias dmesgjp='journalctl -ko short-monotonic --no-hostname'

# backup source to target (no deletion but overwrite)
# show progress, ignoring ext. links
alias rsync-backup='rsync -axvu --safe-links --info=progress2'
# in addition to the above, compress and keep partial files
alias rsync-backup-remote='rsync -axvu --safe-links -Pz'
# same as above but backup files that are to be overwritten/deleted (target)
alias rsync-backup-safe='rsync -axvu --safe-links --info=progress2 --backup'
alias rsync-backup-safe-remote='rsync -axvu --safe-links -Pz --backup'

# sync source to target (delete files in target if missing in source)
alias rsync-sync='rsync -axvu --safe-links --info=progress2 -i --delete'
alias rsync-sync-remote='rsync -axvu --safe-links -Piz --delete'
# same as above but backup files that are to be overwritten/deleted (target)
alias rsync-sync-safe='rsync -axvu --safe-links --info=progress2 -i --delete --backup'
alias rsync-sync-safe-remote='rsync -axvu --safe-links -Piz --delete --backup'

# clone with permissions, links, etc.
alias rsync-clone='rsync -axWS --numeric-ids --info=progress2'
# compare source and target, list all files that are different/new/missing
alias rsync-diff='rsync -axvnc'
alias rsync-diff-quick='rsync -axvnu'
# }}} - GENERAL --------------------------------------------------------------
# editors
# the debian/ubuntu `editor` command uses the system wide default (not always under our control)
# so let's shadow it to ensure it's always our prefered $EDITOR
# Use a function so $EDITOR (which may include args like "vim -N") is word-split correctly.
# Zsh requires ${=var} to force word-splitting; bash splits unquoted $var in command position.
editor() {
  if [[ -n "${ZSH_VERSION-}" ]]; then
    # shellcheck disable=SC2296  # ${=var} is zsh-specific syntax, not valid in bash/sh
    ${=EDITOR} "$@"
  else
    # shellcheck disable=SC2086  # intentional word-split on $EDITOR
    ${EDITOR} "$@"
  fi
}

# the same for nano, since it is commonly used in guides and by AI (no need to rewrite instructions that use nanon)
alias nano='editor'
alias e='emacs -nw'
alias vim='vim -N'  # -N disable nvi compatibility mode, which causes various issues (e.g. with plugins), but note that some scripts may rely on defaults
alias vi='vim -N'
alias v='vim -N'

# the alias can be used to ensure that sudoedit uses $EDITOR instead of $VISUAL (or $SUDO_EDITOR if set)
# e.g. in case emacs/vim is preferrable to vs code, when in desktop environment
# sudoedit priority: $SUDO_EDITOR -> $VISUAL -> $EDITOR
# we intentionally use single quotes to ensur that $EDITOR is expanded at runtime (when alias is used) and not at definition time (here) since the value of EDITOR can be changed at a later stage
alias sudoedit-editor='env SUDO_EDITOR="$EDITOR" sudoedit'
# }}} - DEFAULT APPS ---------------------------------------------------------

# {{{ - SYSTEM ---------------------------------------------------------------
alias ls-disk-uuid='sudo blkid -c /dev/null'
alias ls-part='sudo fdisk -l | egrep "Disk /dev/(sd|md)" | sort | cut -d, -f1'
alias lsblka="lsblk -T -o NAME,MAJ:MIN,RM,RO,FSTYPE,SIZE,FSSIZE,FSAVAIL,FSUSED,FSUSE\%,LABEL,UUID,START,MOUNTPOINTS,OWNER,GROUP,MODE"
alias lsblkd="lsblk -e 1,7 -T -o NAME,MAJ:MIN,RM,FSTYPE,SIZE,FSSIZE,FSAVAIL,FSUSED,FSUSE\%,LABEL,UUID,MOUNTPOINTS"

alias fsck-y='sudo fsck -fyv'
alias fsck-bby='sudo fsck -ccfyv'
alias fsck-bbp='sudo fsck -ccfpv'

alias smart-test='sudo smartctl -t long'
alias smart-test-abort='sudo smartctl -X'
alias smart-error='sudo smartctl -l error'
alias smart-errorx='sudo smartctl -l xerror'
alias smart-attr='sudo smartctl -A'

# query standby status without warking the drive
alias smart-sbstatus='sudo smartctl -n standby -i'
# shellcheck disable=SC2154  # d is assigned by the for loop; shellcheck confused by multi-line alias
alias smart-sbstatus-all='for d in /dev/sd[a-z]; do
    echo $d; sudo smartctl -n standby -i $d;
  done'
alias smart-sbstatus-all-short='for d in /dev/sd[a-z]; do
    echo $d; sudo smartctl -n standby -i $d | grep -o "Device is in STANDBY mode" \
      || echo "Device is ACTIVE";
  done'
alias smart-stats-all='for d in /dev/sd?; do
    echo -n "------\nSMART Device:     $d\n"
    sudo smartctl -a $d | egrep -i "^(Device Model|User Capacity|self-assessment test|\s*[0-9]+ .*0x)"
  done | egrep --color " ([1-9]|[0-9]+[0-9])\$|"'

# send drive to standby (not -Y sleep, which will wake e.g. on query)
alias hdparm-standby='sudo hdparm -y'
alias hdparm-standby-all='sudo hdparm -y /dev/sd[a-z]'
alias udevadm-reload-and-apply='sudo udevadm control --reload-rules && sudo udevadm trigger'

# raid
alias mdstat='cat /proc/mdstat'
# shellcheck disable=SC2142  # $1/$NF are awk field refs, not shell positional params
alias mdstat-md=$'awk \'/^md/ {printf "%s: ", $1}; /blocks/ {print $NF}\' /proc/mdstat'
alias mdstat-sync='cat /sys/block/md*/md/sync_action'
alias mddetails='sudo mdadm --detail /dev/md*'
alias mdexamine='sudo mdadm --examine'
alias mdexamine-all='grep -oE "\b(sd\w)[0-9]+\[[0-9]+\]" /proc/mdstat | grep -oE "^sd\w[0-9]+" | while read d; do echo "> Examining component [$d]"; sudo mdadm --examine "/dev/$d"; echo; done'
alias mdexamine-bitmap-all='grep -oE "\b(sd\w)[0-9]+\[[0-9]+\]" /proc/mdstat | grep -oE "^sd\w[0-9]+" | while read d; do echo "> Examining component [$d] bitmap"; sudo mdadm --examine-bitmap "/dev/$d"; echo; done'
alias mdexamine-badblocks-all='grep -oE "\b(sd\w)[0-9]+\[[0-9]+\]" /proc/mdstat | grep -oE "^sd\w[0-9]+" | while read d; do echo "> Examining component [$d] badblocks"; sudo mdadm --examine-badblocks "/dev/$d"; echo; done'

alias mdscrub='echo check | sudo tee /sys/block/md0/md/sync_action'
alias mdscrub-abort='echo idle | sudo tee /sys/block/md0/md/sync_action'
alias mdscrub-stats='sudo cat /sys/block/md0/md/mismatch_cnt'

alias mdcheck='/usr/share/mdadm/checkarray'
# }}} - SYSTEM ---------------------------------------------------------------

